<Application x:Class="VietTravel.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:VietTravel.UI.ViewModels"
             xmlns:views="clr-namespace:VietTravel.UI.Views"
             xmlns:converters="clr-namespace:VietTravel.UI.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="LightBlue" SecondaryColor="Blue" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
                <ResourceDictionary Source="Themes/AppleDesignSystem.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:StringMatchConverter x:Key="StringMatchConverter"/>

            <!-- Legacy compatibility for MainWindow.xaml -->
            <SolidColorBrush x:Key="AppBackground" Color="White"/>
            <SolidColorBrush x:Key="AppText" Color="Black"/>
            <SolidColorBrush x:Key="AppPrimaryAccent" Color="#007AFF"/>
            <Color x:Key="BlurShadowColor">#007AFF</Color>

            <!-- DataTemplates: ViewModel => View mapping -->
            <DataTemplate DataType="{x:Type viewmodels:LoginViewModel}">
                <views:LoginView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:RegistrationViewModel}">
                <views:RegisterView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:AdminShellViewModel}">
                <views:AdminShellView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:CustomerViewModel}">
                <views:CustomerView />
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>
</Application>
