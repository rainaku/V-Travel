<UserControl x:Class="VietTravel.UI.Views.AdminProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:VietTravel.UI.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:AdminProfileViewModel}"
             Background="Transparent">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="100" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="#40FFFFFF">
                <Border.Effect>
                    <BlurEffect Radius="20"/>
                </Border.Effect>
            </Border>
            <ProgressBar IsIndeterminate="True" Style="{StaticResource MaterialDesignCircularProgressBar}" 
                         Width="40" Height="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Grid>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Text="Hồ sơ cá nhân" Style="{StaticResource HeadingLargeStyle}"/>
            <TextBlock Text="Quản lý thông tin tài khoản và ảnh đại diện của bạn" 
                       Style="{StaticResource CaptionStyle}" FontSize="14" Margin="0,6,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                
                <!-- Left Column: Avatar & Summary -->
                <Border Style="{StaticResource AppleCard}" Width="300" VerticalAlignment="Top" Margin="0,0,32,0" Padding="12">
                    <StackPanel>
                        <Grid HorizontalAlignment="Center" Margin="0,20,0,16">
                            <Ellipse Width="120" Height="120">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#007AFF" Offset="0"/>
                                        <GradientStop Color="#AF52DE" Offset="1"/>
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            
                            <!-- Avatar Image if exists -->
                            <Ellipse Width="120" Height="120" Visibility="{Binding HasAvatar, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>

                            <TextBlock Text="{Binding FullName[0]}" Foreground="White" FontSize="48" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding HasAvatar, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                            <!-- Upload Loading Overlay -->
                            <Grid Width="120" Height="120" Visibility="{Binding IsUploading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Ellipse Fill="#80000000"/>
                                <ProgressBar IsIndeterminate="True" Width="30" Height="30" 
                                             Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             Foreground="White"/>
                            </Grid>
                        </Grid>

                        <TextBlock Text="{Binding FullName}" Style="{StaticResource HeadingMediumStyle}" 
                                   HorizontalAlignment="Center" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding UserRole}" Style="{StaticResource CaptionStyle}" 
                                   HorizontalAlignment="Center" Margin="0,4,0,24"/>

                        <Button Style="{StaticResource AppleGhostButton}" Command="{Binding ChangeAvatarCommand}"
                                IsEnabled="{Binding IsUploading, Converter={StaticResource InverseBooleanConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CameraOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ChangeAvatarButtonText}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        
                        <Border Height="1" Background="{StaticResource DividerBrush}" Margin="0,20,0,20"/>
                        
                        <StackPanel Margin="8,0">
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Tên đăng nhập" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock Text="{Binding Username}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Trạng thái" Style="{StaticResource CaptionStyle}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Đang hoạt động" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Right Column: Form -->
                <Border Style="{StaticResource AppleCard}" Width="600" VerticalAlignment="Top" Padding="28">
                    <StackPanel>
                        <TextBlock Text="Thông tin chi tiết" Style="{StaticResource HeadingSmallStyle}" Margin="0,0,0,24"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Full Name -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,20">
                                <TextBlock Text="Họ và tên" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource AppleTextBox}" materialDesign:HintAssist.Hint="Nhập họ tên"/>
                            </StackPanel>

                            <!-- Phone -->
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,20">
                                <TextBlock Text="Số điện thoại" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource AppleTextBox}" materialDesign:HintAssist.Hint="Nhập số điện thoại"/>
                            </StackPanel>

                            <!-- Email -->
                            <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,0,0,20">
                                <TextBlock Text="Địa chỉ Email" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource AppleTextBox}" materialDesign:HintAssist.Hint="Nhập email"/>
                            </StackPanel>

                            <!-- Address -->
                            <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="0,0,0,32">
                                <TextBlock Text="Địa chỉ" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource AppleTextBox}" materialDesign:HintAssist.Hint="Nhập địa chỉ"
                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" VerticalContentAlignment="Top" Padding="12,10"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{StaticResource DividerBrush}" Margin="0,0,0,28"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ApplePrimaryButton}" Command="{Binding SaveProfileCommand}" Width="160">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsSaving, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Lưu thay đổi" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ProgressBar IsIndeterminate="True" Width="20" Height="20" 
                                                 Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                 Foreground="White"
                                                 Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
