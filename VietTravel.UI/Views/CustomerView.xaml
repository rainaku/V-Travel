<UserControl x:Class="VietTravel.UI.Views.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BackgroundBrush}">

    <Border CornerRadius="16" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="28,16">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Avatar -->
                        <Grid Width="40" Height="40" Margin="0,0,14,0">
                            <Ellipse Width="40" Height="40">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#007AFF" Offset="0"/>
                                        <GradientStop Color="#5AC8FA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <materialDesign:PackIcon Kind="AccountOutline" Width="20" Height="20" Foreground="White"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">
                                <Run Text="Xin chào, "/><Run Text="{Binding FullName, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="Khách hàng" FontFamily="{StaticResource AppFont}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Style="{StaticResource AppleGhostButton}" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Command="{Binding LogoutCommand}" Foreground="{StaticResource ErrorBrush}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Logout" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Đăng xuất" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Content Area with Tabs -->
            <TabControl Grid.Row="1" TabStripPlacement="Top" Padding="0" Margin="28,20,28,20"
                        Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                        <Setter Property="Padding" Value="16,10"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="border" Padding="{TemplateBinding Padding}" Background="Transparent"
                                            BorderBrush="Transparent" BorderThickness="0,0,0,2" Margin="0,0,4,0" Cursor="Hand">
                                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Đặt Tour -->
                <TabItem Header="🗺️  Đặt Tour">
                    <Border Style="{StaticResource AppleCard}" Margin="0,16,0,0">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Ellipse Width="72" Height="72" Fill="#0A007AFF"/>
                                <materialDesign:PackIcon Kind="MapSearchOutline" Width="36" Height="36" Foreground="{StaticResource PrimaryBrush}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Đặt Tour Du Lịch" FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Chọn tour yêu thích và đặt chỗ ngay" FontFamily="{StaticResource AppFont}" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Tour Của Tôi -->
                <TabItem Header="✈️  Tour Của Tôi">
                    <Border Style="{StaticResource AppleCard}" Margin="0,16,0,0">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Ellipse Width="72" Height="72" Fill="#0A34C759"/>
                                <materialDesign:PackIcon Kind="TicketConfirmationOutline" Width="36" Height="36" Foreground="{StaticResource SuccessBrush}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Tour Đã Đặt" FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Xem lại các tour đã đặt của bạn" FontFamily="{StaticResource AppFont}" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Các Tour V-Travel -->
                <TabItem Header="🌏  Các Tour V-Travel">
                    <Border Style="{StaticResource AppleCard}" Margin="0,16,0,0">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Ellipse Width="72" Height="72" Fill="#0AFF9500"/>
                                <materialDesign:PackIcon Kind="CompassOutline" Width="36" Height="36" Foreground="{StaticResource WarningBrush}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Khám Phá Tour" FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Duyệt các tour hấp dẫn từ Viet Travel" FontFamily="{StaticResource AppFont}" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Thông Tin Cá Nhân -->
                <TabItem Header="👤  Thông Tin">
                    <Border Style="{StaticResource AppleCard}" Margin="0,16,0,0">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Ellipse Width="72" Height="72" Fill="#0AAF52DE"/>
                                <materialDesign:PackIcon Kind="AccountEditOutline" Width="36" Height="36" Foreground="{StaticResource AccentBrush}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Thông Tin Cá Nhân" FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Quản lý hồ sơ và thông tin cá nhân" FontFamily="{StaticResource AppFont}" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
