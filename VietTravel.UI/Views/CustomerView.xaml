<UserControl Style="{StaticResource AnimatedPageStyle}" x:Class="VietTravel.UI.Views.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:VietTravel.UI.Converters"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:StringMatchConverter x:Key="PageConverter"/>
        <BackEase x:Key="MotionEaseOut" EasingMode="EaseOut" Amplitude="0.24"/>
        <CubicEase x:Key="MotionEaseInOut" EasingMode="EaseInOut"/>
        <BackEase x:Key="MotionSpringOut" EasingMode="EaseOut" Amplitude="0.32"/>

        <Style x:Key="AnimatedPageScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="8"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsVisible" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard x:Name="FadeInSlideUp">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.30"
                                                 EasingFunction="{StaticResource MotionEaseOut}"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="15" To="0" Duration="0:0:0.30"
                                                 EasingFunction="{StaticResource MotionEaseOut}"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <RemoveStoryboard BeginStoryboardName="FadeInSlideUp"/>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BookingActionButtonBase" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BookingCancelActionButton" TargetType="Button" BasedOn="{StaticResource BookingActionButtonBase}">
            <Setter Property="Foreground" Value="#912D2D"/>
            <Setter Property="Background" Value="#FDEEEE"/>
            <Setter Property="BorderBrush" Value="#F6D7D7"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FBE3E3"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#F7D7D7"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#A7ADB6"/>
                    <Setter Property="Background" Value="#F4F5F7"/>
                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BookingRatingActionButton" TargetType="Button" BasedOn="{StaticResource BookingActionButtonBase}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="#EEF1F6"/>
            <Setter Property="BorderBrush" Value="#E1E5ED"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E4E9F2"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#DCE2EC"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#A7ADB6"/>
                    <Setter Property="Background" Value="#F4F5F7"/>
                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- User Profile Header -->
                <Border Grid.Row="0" Padding="20,24,20,20">
                    <StackPanel>
                        <Grid Width="56" Height="56" HorizontalAlignment="Left" Margin="0,0,0,14">
                            <Ellipse Width="56" Height="56">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#007AFF" Offset="0"/>
                                        <GradientStop Color="#5AC8FA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Image Source="{Binding AvatarUrl}" Width="56" Height="56" Stretch="UniformToFill">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                                <Image.Clip>
                                    <EllipseGeometry Center="28,28" RadiusX="28" RadiusY="28"/>
                                </Image.Clip>
                            </Image>
                            <TextBlock Text="{Binding UserInitials}" FontFamily="{StaticResource AppFont}" FontSize="20" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <TextBlock Text="{Binding FullName}" FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Khách hàng V-Travel" FontFamily="{StaticResource AppFont}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Divider -->
                <Border Grid.Row="1" Height="1" Background="{StaticResource DividerBrush}" Margin="16,0"/>

                <!-- Navigation Items -->
                <StackPanel Grid.Row="2" Margin="0,12,0,0">
                    <TextBlock Text="MENU" FontFamily="{StaticResource AppFont}" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextTertiaryBrush}" Margin="24,8,0,8"/>

                    <RadioButton Style="{StaticResource SidebarButton}" GroupName="CustomerNav"
                                 IsChecked="{Binding SelectedPage, Converter={StaticResource PageConverter}, ConverterParameter=Explore}"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Explore">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CompassOutline" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Khám phá Tour" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarButton}" GroupName="CustomerNav"
                                 IsChecked="{Binding SelectedPage, Converter={StaticResource PageConverter}, ConverterParameter=Book}"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Book">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TicketOutline" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Đặt Tour" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarButton}" GroupName="CustomerNav"
                                 IsChecked="{Binding SelectedPage, Converter={StaticResource PageConverter}, ConverterParameter=MyBookings}"
                                 Command="{Binding NavigateToCommand}" CommandParameter="MyBookings">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BookmarkOutline" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Lịch sử Booking" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <TextBlock Text="TÀI KHOẢN" FontFamily="{StaticResource AppFont}" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextTertiaryBrush}" Margin="24,20,0,8"/>

                    <RadioButton Style="{StaticResource SidebarButton}" GroupName="CustomerNav"
                                 IsChecked="{Binding SelectedPage, Converter={StaticResource PageConverter}, ConverterParameter=Profile}"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Profile">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountCircleOutline" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Thông tin cá nhân" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarButton}" GroupName="CustomerNav"
                                 IsChecked="{Binding SelectedPage, Converter={StaticResource PageConverter}, ConverterParameter=Notifications}"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Notifications">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="BellOutline" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Thông báo" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{StaticResource ErrorBrush}" CornerRadius="9" MinWidth="18"
                                    Height="18" Padding="6,0,6,0" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UnreadNotificationCount, Mode=OneWay}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding UnreadNotificationCount, Mode=OneWay}" Foreground="White" FontSize="10"
                                           FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </RadioButton>

                    <StackPanel Visibility="{Binding IsDebugMenuVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="DEBUG" FontFamily="{StaticResource AppFont}" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="24,20,0,8"/>
                        <RadioButton Style="{StaticResource SidebarButton}" GroupName="CustomerNav"
                                     IsChecked="{Binding SelectedPage, Converter={StaticResource PageConverter}, ConverterParameter=Debug}"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Debug">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="BugOutline" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Debug Tools" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </StackPanel>

                <!-- Sidebar Footer -->
                <Border Grid.Row="3" Padding="16,12" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,0">
                    <Button Style="{StaticResource AppleGhostButton}" HorizontalAlignment="Stretch" Height="40"
                            Command="{Binding LogoutCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Logout" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{StaticResource ErrorBrush}"/>
                            <TextBlock Text="Đăng xuất" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource ErrorBrush}"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT AREA ═══ -->
        <Grid Grid.Column="1">
            <Grid x:Name="CustomerMainContentHost">
                <Grid.Effect>
                    <BlurEffect x:Name="CustomerMainContentBlurEffect" Radius="0" KernelType="Gaussian"/>
                </Grid.Effect>

            <!-- ──── PAGE: EXPLORE ──── -->
            <Grid Visibility="{Binding SelectedPage, Converter={StaticResource PageConverter}, ConverterParameter=Explore}">
                <ScrollViewer x:Name="ExploreScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource AnimatedPageScrollViewer}"
                              Loaded="ExploreScrollViewer_OnLoaded"
                              ScrollChanged="ExploreScrollViewer_OnScrollChanged">
                <StackPanel Margin="24,24,24,24">
                    <!-- Header / Hero -->
                    <Border x:Name="ExploreHeroCard" Margin="0,0,0,24" CornerRadius="20" ClipToBounds="True" Height="250">
                        <Grid x:Name="ExploreHeroCardContent"
                              Loaded="ExploreHeroCardContent_OnLoaded"
                              SizeChanged="ExploreHeroCardContent_OnSizeChanged">
                            <MediaElement x:Name="ExploreHeroVideo"
                                          Stretch="UniformToFill"
                                          LoadedBehavior="Manual"
                                          UnloadedBehavior="Manual"
                                          IsMuted="True"
                                          Volume="0"
                                          MediaEnded="ExploreHeroVideo_OnMediaEnded"
                                          MediaFailed="ExploreHeroVideo_OnMediaFailed"/>

                            <Grid Margin="24">
                            <Grid.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.68" Direction="270"/>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Ellipse Width="160" Height="160" Fill="#1FFFFFFF" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-78,-62,0"/>
                            <Ellipse Width="96" Height="96" Fill="#14FFFFFF" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,96,-46"/>

                            <StackPanel Grid.Column="0">
                                <Border Background="#26FFFFFF" CornerRadius="10" Padding="10,5" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Sparkles" Width="14" Height="14" Foreground="White" Margin="0,0,6,0"/>
                                        <TextBlock Text="Gợi ý hôm nay" FontFamily="{StaticResource AppFont}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Margin="0,12,0,0" FontFamily="{StaticResource AppFont}" FontSize="34" FontWeight="Bold" Foreground="White" LineHeight="40">
                                    <Run Text="Khám phá mọi cung đường"/>
                                    <LineBreak/>
                                    <Run Text="cùng VTravel"/>
                                </TextBlock>

                                <TextBlock Margin="0,12,0,0" FontFamily="{StaticResource AppFont}" FontSize="14" Foreground="#EAF6FF" TextWrapping="Wrap">
                                    Tìm chuyến đi phù hợp ngân sách, lịch trình và điểm đến yêu thích.
                                    Chọn nhanh và đặt ngay chỉ trong vài thao tác.
                                </TextBlock>

                                <WrapPanel Margin="0,14,0,0">
                                    <Border Background="#26FFFFFF" CornerRadius="9" Padding="10,5" Margin="0,0,8,0">
                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold" Foreground="White">
                                            <Run Text="{Binding TotalToursAvailable, Mode=OneWay}"/>
                                            <Run Text=" tour khả dụng"/>
                                        </TextBlock>
                                    </Border>
                                    <Border Background="#26FFFFFF" CornerRadius="9" Padding="10,5">
                                        <TextBlock Text="Hỗ trợ 24/7" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>

                            <Border Grid.Column="1" Width="120" Height="120" CornerRadius="60" Background="#26FFFFFF" VerticalAlignment="Center" Margin="24,0,0,0">
                                <Grid>
                                    <Ellipse Width="100" Height="100" Fill="#1EFFFFFF"/>
                                    <Image Source="/UI/Assets/logo-white.png" Width="84" Height="84" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Effect>
                                            <DropShadowEffect Color="White" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                                        </Image.Effect>
                                    </Image>
                                </Grid>
                            </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Search Bar -->
                    <Border Style="{StaticResource AppleCard}" Padding="16" Margin="0,0,0,24">
                        <Grid>
                            <TextBox Text="{Binding TourSearchText, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource AppleSearchBox}"
                                     materialDesign:HintAssist.Hint="Tìm kiếm tour theo tên, điểm đến..."
                                     FontSize="14"/>
                            <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" Foreground="{StaticResource TextTertiaryBrush}"
                                                     VerticalAlignment="Center" Margin="14,0,0,0" IsHitTestVisible="False"/>
                        </Grid>
                    </Border>

                    <!-- Tour Cards Grid -->
                    <ItemsControl ItemsSource="{Binding FilteredTours}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,14,18" CornerRadius="16" Background="White" ClipToBounds="True"
                                        RenderTransformOrigin="0.5,0.5"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.ShowTourDetailsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            <TranslateTransform Y="0"/>
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="2" Opacity="0.05" Direction="270"/>
                                    </Border.Effect>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0" To="1" Duration="0:0:0.42"
                                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.985"/>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.30" Value="1.004" EasingFunction="{StaticResource MotionSpringOut}"/>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.42" Value="1"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.985"/>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.30" Value="1.004" EasingFunction="{StaticResource MotionSpringOut}"/>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.42" Value="1"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)">
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0" Value="9"/>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.42" Value="0" EasingFunction="{StaticResource MotionEaseOut}"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>

                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                     To="1.012" Duration="0:0:0.30" EasingFunction="{StaticResource MotionEaseOut}"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                     To="1.012" Duration="0:0:0.30" EasingFunction="{StaticResource MotionEaseOut}"/>

                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>

                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                     To="1" Duration="0:0:0.36" EasingFunction="{StaticResource MotionEaseInOut}"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                     To="1" Duration="0:0:0.36" EasingFunction="{StaticResource MotionEaseInOut}"/>

                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>

                                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                     To="0.992" Duration="0:0:0.12" EasingFunction="{StaticResource MotionEaseOut}"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                     To="0.992" Duration="0:0:0.12" EasingFunction="{StaticResource MotionEaseOut}"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>

                                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                     To="1.01" Duration="0:0:0.18" EasingFunction="{StaticResource MotionSpringOut}"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                     To="1.01" Duration="0:0:0.18" EasingFunction="{StaticResource MotionSpringOut}"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <!-- Tour Image Header -->
                                        <Border Grid.Row="0" Height="140" CornerRadius="16,16,0,0">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" 
                                                              Command="{Binding DataContext.ShowTourDetailsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <Grid>
                                                <Border Background="#20000000" CornerRadius="16,16,0,0" IsHitTestVisible="False"/>
                                                <!-- Destination badge -->
                                                <Border Background="#40000000" CornerRadius="8" Padding="10,5" 
                                                        HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12,0,0,12">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="MapMarkerOutline" Width="14" Height="14" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Destination}" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Duration badge -->
                                                <Border Background="#40000000" CornerRadius="8" Padding="10,5" 
                                                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,12,12">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="ClockOutline" Width="14" Height="14" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="White" FontWeight="SemiBold">
                                                            <Run Text="{Binding DurationDays, Mode=OneWay}"/><Run Text=" ngày"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <!-- Tour Info -->
                                        <Grid Grid.Row="1" Margin="16,14,16,16">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{Binding Name}" FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="1" Text="{Binding Description}" FontFamily="{StaticResource AppFont}" FontSize="12"
                                                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,6,0,0"
                                                       TextTrimming="CharacterEllipsis" MaxHeight="34" TextWrapping="Wrap"/>
                                            <Grid Grid.Row="3" Margin="0,12,0,0">
                                                <StackPanel>
                                                    <Grid>
                                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center">
                                                            <Run Text="{Binding BasePrice, StringFormat={}{0:N0}, Mode=OneWay}"/><Run Text=" đ" FontSize="13" FontWeight="Normal"/>
                                                        </TextBlock>
                                                        <TextBlock Text="/người" FontFamily="{StaticResource AppFont}" FontSize="12"
                                                                   Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                                    </Grid>
                                                    <StackPanel Margin="0,8,0,0">
                                                        <TextBlock Text="{Binding RatingStarsText}" FontFamily="{StaticResource AppFont}" FontSize="13"
                                                                   Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding RatingSummaryText}" FontFamily="{StaticResource AppFont}" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty tours -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,48,0,56">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilteredTours.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Grid Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Ellipse Width="72" Height="72" Fill="#0A007AFF"/>
                            <materialDesign:PackIcon Kind="CompassOutline" Width="36" Height="36" Foreground="{StaticResource PrimaryBrush}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Không tìm thấy tour nào" HorizontalAlignment="Center"
                                   FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Thử tìm kiếm với từ khóa khác" HorizontalAlignment="Center"
                                   FontFamily="{StaticResource AppFont}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>

                <Border x:Name="ExploreTopFadeOverlay"
                        Height="20"
                        VerticalAlignment="Top"
                        Background="{StaticResource BackgroundBrush}"
                        IsHitTestVisible="False"
                        Opacity="0">
                    <Border.OpacityMask>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF000000" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.OpacityMask>
                </Border>

                <Border x:Name="ExploreBottomFadeOverlay"
                        Height="24"
                        VerticalAlignment="Bottom"
                        Background="{StaticResource BackgroundBrush}"
                        IsHitTestVisible="False"
                        Opacity="0">
                    <Border.OpacityMask>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#FF000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.OpacityMask>
                </Border>
            </Grid>

            <!-- ──── PAGE: BOOK TOUR ──── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource AnimatedPageScrollViewer}"
                          Visibility="{Binding SelectedPage, Converter={StaticResource PageConverter}, ConverterParameter=Book}">
                <StackPanel Margin="32,28,32,32">
                    <!-- Header -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="Đặt Tour Du Lịch" Style="{StaticResource HeadingLargeStyle}"/>
                        <TextBlock Text="Chọn lịch trình và đặt chỗ ngay hôm nay" Style="{StaticResource CaptionStyle}" FontSize="14" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Available Departures as Cards -->
                    <TextBlock Text="Lịch trình đang mở" Style="{StaticResource SubheadingStyle}" Margin="0,0,0,16"/>

                    <Border Background="#EAF3FF" CornerRadius="10" Padding="12,9" Margin="0,0,0,14">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBookDestinationFilterActive}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center">
                                <Run Text="Đang lọc lịch trình tại: "/>
                                <Run Text="{Binding BookDestinationFilter}" FontWeight="Bold"/>
                            </TextBlock>

                            <Button Grid.Column="1"
                                    Style="{StaticResource AppleGhostButton}"
                                    Command="{Binding ClearBookDestinationFilterCommand}"
                                    Padding="8,4">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FilterRemoveOutline" Width="14" Height="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="Xem tất cả" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding FilteredAvailableDepartures}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource AppleCardHover}" Margin="0,0,0,12" Padding="0" Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Color accent bar -->
                                        <Border Grid.Column="0" CornerRadius="16,0,0,16">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#007AFF" Offset="0"/>
                                                    <GradientStop Color="#5AC8FA" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1" Margin="20,18,16,18">
                                            <TextBlock Text="{Binding TourName}" FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <materialDesign:PackIcon Kind="MapMarkerOutline" Width="14" Height="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Destination}" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock Text="  •  " FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"/>
                                                <materialDesign:PackIcon Kind="CalendarOutline" Width="14" Height="14" Foreground="{StaticResource SuccessBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                    <Run Text="{Binding StartDateFormatted}"/>
                                                    <Run Text=" - "/>
                                                    <Run Text="{Binding EndDateFormatted}"/>
                                                </TextBlock>
                                                <TextBlock Text="  •  " FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"/>
                                                <materialDesign:PackIcon Kind="ClockOutline" Width="14" Height="14" Foreground="{StaticResource WarningBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                    <Run Text="{Binding DurationDays, Mode=OneWay}"/><Run Text=" ngày"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <materialDesign:PackIcon Kind="AccountTieOutline" Width="14" Height="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="HDV: " FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding GuideName}" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <Border Background="#0A34C759" CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                                                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold">
                                                        <Run Text="Còn "/><Run Text="{Binding AvailableSlots, Mode=OneWay}"/><Run Text=" chỗ"/>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Price + Book Button -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0" Width="160">
                                            <TextBlock Text="{Binding PriceFormatted}" FontFamily="{StaticResource AppFont}" FontSize="20"
                                                       FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="/người" FontFamily="{StaticResource AppFont}" FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Right" Margin="0,2,0,8"/>
                                            <Button Style="{StaticResource ApplePrimaryButton}" Padding="16,8" HorizontalAlignment="Right"
                                                    Command="{Binding DataContext.ShowBookingFormCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="TicketOutline" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Đặt ngay" VerticalAlignment="Center" FontSize="13"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty departures -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,48,0,56">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilteredAvailableDepartures.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Grid Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Ellipse Width="72" Height="72" Fill="#0AFF9500"/>
                            <materialDesign:PackIcon Kind="CalendarBlankOutline" Width="36" Height="36" Foreground="{StaticResource WarningBrush}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Chưa có lịch trình nào" HorizontalAlignment="Center"
                                   FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Vui lòng quay lại sau khi có lịch khởi hành mới" HorizontalAlignment="Center"
                                   FontFamily="{StaticResource AppFont}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- ──── PAGE: MY BOOKINGS ──── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource AnimatedPageScrollViewer}"
                          Visibility="{Binding SelectedPage, Converter={StaticResource PageConverter}, ConverterParameter=MyBookings}">
                <StackPanel Margin="32,28,32,32">
                    <!-- Header -->
                    <Grid Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Lịch sử Booking" Style="{StaticResource HeadingLargeStyle}"/>
                            <TextBlock Text="Theo dõi các tour bạn đã đặt" Style="{StaticResource CaptionStyle}" FontSize="14" Margin="0,6,0,0"/>
                        </StackPanel>
                        <Button Style="{StaticResource AppleGhostButton}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Command="{Binding RefreshDataCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Làm mới" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Stats Row -->
                    <UniformGrid Columns="3" Margin="0,0,0,24">
                        <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="44" Height="44" Margin="0,0,14,0">
                                    <Ellipse Width="44" Height="44" Fill="#1A007AFF"/>
                                    <materialDesign:PackIcon Kind="TicketOutline" Width="22" Height="22" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotalBookingsCount}" FontFamily="{StaticResource AppFont}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Tổng booking" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}" Margin="5,0,5,0">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="44" Height="44" Margin="0,0,14,0">
                                    <Ellipse Width="44" Height="44" Fill="#1AFF9500"/>
                                    <materialDesign:PackIcon Kind="ClockOutline" Width="22" Height="22" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding PendingBookingsCount}" FontFamily="{StaticResource AppFont}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Đang chờ" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}" Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="44" Height="44" Margin="0,0,14,0">
                                    <Ellipse Width="44" Height="44" Fill="#1A34C759"/>
                                    <materialDesign:PackIcon Kind="CheckCircleOutline" Width="22" Height="22" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ConfirmedBookingsCount}" FontFamily="{StaticResource AppFont}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Đã xác nhận" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Style="{StaticResource AppleCard}" Padding="16" Margin="0,0,0,20"
                            Visibility="{Binding HasRatingSchemaWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertCircleOutline" Width="18" Height="18" Margin="0,0,10,0"
                                                     Foreground="{StaticResource WarningBrush}" VerticalAlignment="Top"/>
                            <TextBlock Text="{Binding RatingSchemaWarningSummary}" TextWrapping="Wrap"
                                       FontFamily="{StaticResource AppFont}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource AppleCard}" Padding="24" Margin="0,0,0,20"
                            Visibility="{Binding IsRatingFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding RatingFormTitle}" FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14"/>
                            <TextBlock Text="{Binding RatingFormContextText}" FontFamily="{StaticResource AppFont}" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding RatingFormScopeNotice}"
                                       FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,6,0,0" TextWrapping="Wrap"/>

                            <StackPanel Margin="0,16,0,0">
                                <Border Background="#F7F8FA" CornerRadius="12" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="Đánh giá tour *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding TourRatingFormStarsText}" FontFamily="{StaticResource AppFont}" FontSize="20"
                                                   FontWeight="Bold" Foreground="{StaticResource WarningBrush}" Margin="0,6,0,8"/>
                                        <Slider Minimum="1" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True"
                                                Value="{Binding FormTourRatingValue, UpdateSourceTrigger=PropertyChanged}"
                                                TickPlacement="BottomRight"/>
                                        <TextBlock Text="Nhận xét tour *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,12,0,6"/>
                                        <TextBox Text="{Binding FormTourRatingComment, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True"
                                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="90"
                                                 Style="{StaticResource AppleSearchBox}"
                                                 materialDesign:HintAssist.Hint="{Binding TourRatingFormCommentHint}"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#F7F8FA" CornerRadius="12" Padding="16" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Đánh giá hướng dẫn viên *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SelectedRatingBooking.GuideName, StringFormat=HDV: {0}}"
                                                   FontFamily="{StaticResource AppFont}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding GuideRatingFormStarsText}" FontFamily="{StaticResource AppFont}" FontSize="20"
                                                   FontWeight="Bold" Foreground="{StaticResource WarningBrush}" Margin="0,6,0,8"/>
                                        <Slider Minimum="1" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True"
                                                Value="{Binding FormGuideRatingValue, UpdateSourceTrigger=PropertyChanged}"
                                                TickPlacement="BottomRight"/>
                                        <TextBlock Text="Nhận xét HDV *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,12,0,6"/>
                                        <TextBox Text="{Binding FormGuideRatingComment, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True"
                                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="90"
                                                 Style="{StaticResource AppleSearchBox}"
                                                 materialDesign:HintAssist.Hint="{Binding GuideRatingFormCommentHint}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                                <Button Style="{StaticResource AppleGhostButton}" Content="Hủy" Command="{Binding CancelRatingFormCommand}" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource ApplePrimaryButton}" Content="{Binding RatingFormActionText}" Command="{Binding SaveRatingCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Booking Cards -->
                    <ItemsControl ItemsSource="{Binding MyBookings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource AppleCard}" Padding="0" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Status color bar -->
                                        <Border Grid.Column="0" CornerRadius="16,0,0,16">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding StatusColor}"/>
                                            </Border.Background>
                                        </Border>

                                        <Grid Grid.Column="1" Margin="20,16,20,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding TourName}" FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <WrapPanel Margin="0,6,0,0" ItemHeight="18">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                                        <materialDesign:PackIcon Kind="MapMarkerOutline" Width="14" Height="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Destination}" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                                        <materialDesign:PackIcon Kind="CalendarRange" Width="14" Height="14" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                            <Run Text="{Binding StartDateFormatted}"/>
                                                            <Run Text=" - "/>
                                                            <Run Text="{Binding EndDateFormatted}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="ClockOutline" Width="14" Height="14" Foreground="{StaticResource WarningBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                            <Run Text="{Binding DurationDays}"/>
                                                            <Run Text=" ngày"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </WrapPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <materialDesign:PackIcon Kind="AccountTieOutline" Width="14" Height="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                        <Run Text="HDV: "/>
                                                        <Run Text="{Binding GuideName}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <WrapPanel Margin="0,10,0,0">
                                                    <Border Background="#0A007AFF" CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource PrimaryBrush}">
                                                            <Run Text="Khởi hành: "/>
                                                            <Run Text="{Binding DepartureDate, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <Border Background="#0A86868B" CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                                            <Run Text="{Binding GuestCount, Mode=OneWay}"/>
                                                            <Run Text=" khách"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <Border Background="#0A86868B" CornerRadius="6" Padding="8,3">
                                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                                            <Run Text="Đặt: "/>
                                                            <Run Text="{Binding BookingDateFormatted, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </Border>
                                                </WrapPanel>
                                                <TextBlock FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0"
                                                           Text="{Binding AvailableSlots, StringFormat=Còn {0} chỗ}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AvailableSlots}" Value="0">
                                                                    <Setter Property="Text" Value="Hết chỗ"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Border Background="#F7F8FA" CornerRadius="12" Padding="12" Margin="0,12,0,0"
                                                        Visibility="{Binding HasRating, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <StackPanel>
                                                        <WrapPanel>
                                                            <TextBlock Text="{Binding RatingStarsText}" FontFamily="{StaticResource AppFont}" FontSize="14"
                                                                       FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}" Margin="0,0,10,0"/>
                                                            <Border CornerRadius="7" Padding="8,3">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding RatingStatusColor}" Opacity="0.12"/>
                                                                </Border.Background>
                                                                <TextBlock Text="{Binding RatingStatusLabel}" FontFamily="{StaticResource AppFont}" FontSize="11" FontWeight="SemiBold">
                                                                    <TextBlock.Foreground>
                                                                        <SolidColorBrush Color="{Binding RatingStatusColor}"/>
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                            </Border>
                                                        </WrapPanel>
                                                        <TextBlock Text="{Binding RatingCommentPreview}" FontFamily="{StaticResource AppFont}" FontSize="12"
                                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                                        <Border Background="#0A007AFF" CornerRadius="8" Padding="10,8" Margin="0,8,0,0"
                                                                Visibility="{Binding HasAdminReply, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <StackPanel>
                                                                <TextBlock Text="Phản hồi từ Admin" FontFamily="{StaticResource AppFont}" FontSize="11"
                                                                           FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                                                                <TextBlock Text="{Binding RatingAdminReplyPreview}" FontFamily="{StaticResource AppFont}" FontSize="12"
                                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>

                                                <Border Background="#F7F8FA" CornerRadius="12" Padding="12" Margin="0,12,0,0"
                                                        Visibility="{Binding HasGuideRating, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <StackPanel>
                                                        <WrapPanel VerticalAlignment="Center">
                                                            <TextBlock Text="Đánh giá HDV" FontFamily="{StaticResource AppFont}" FontSize="12"
                                                                       FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,10,0"/>
                                                            <TextBlock Text="{Binding GuideRatingStarsText}" FontFamily="{StaticResource AppFont}" FontSize="14"
                                                                       FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}" Margin="0,0,10,0"/>
                                                            <Border CornerRadius="7" Padding="8,3">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding GuideRatingStatusColor}" Opacity="0.12"/>
                                                                </Border.Background>
                                                                <TextBlock Text="{Binding GuideRatingStatusLabel}" FontFamily="{StaticResource AppFont}" FontSize="11" FontWeight="SemiBold">
                                                                    <TextBlock.Foreground>
                                                                        <SolidColorBrush Color="{Binding GuideRatingStatusColor}"/>
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                            </Border>
                                                        </WrapPanel>
                                                        <TextBlock Text="{Binding GuideRatingCommentPreview}" FontFamily="{StaticResource AppFont}" FontSize="12"
                                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                                        <Border Background="#0A007AFF" CornerRadius="8" Padding="10,8" Margin="0,8,0,0"
                                                                Visibility="{Binding HasGuideAdminReply, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <StackPanel>
                                                                <TextBlock Text="Phản hồi từ Admin" FontFamily="{StaticResource AppFont}" FontSize="11"
                                                                           FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                                                                <TextBlock Text="{Binding GuideRatingAdminReplyPreview}" FontFamily="{StaticResource AppFont}" FontSize="12"
                                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <!-- Status badge -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="176" Margin="16,0,0,0">
                                                <TextBlock Text="{Binding PriceFormatted}" FontFamily="{StaticResource AppFont}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="/người" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Right" Margin="0,-2,0,8"/>
                                                <Border CornerRadius="8" Padding="12,6" HorizontalAlignment="Right">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding StatusColor}" Opacity="0.1"/>
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding Status}" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold">
                                                        <TextBlock.Foreground>
                                                            <SolidColorBrush Color="{Binding StatusColor}"/>
                                                        </TextBlock.Foreground>
                                                    </TextBlock>
                                                </Border>

                                                <Button Style="{StaticResource BookingCancelActionButton}" Margin="0,10,0,0" HorizontalAlignment="Stretch"
                                                        Visibility="{Binding ShowCancelButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        IsEnabled="{Binding CanCancel, Mode=OneWay}"
                                                        ToolTip="{Binding CancelDisabledReason, Mode=OneWay}"
                                                        Command="{Binding DataContext.CancelMyBookingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                                 Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                                            <materialDesign:PackIcon.Style>
                                                                <Style TargetType="materialDesign:PackIcon">
                                                                    <Setter Property="Kind" Value="CloseCircleOutline"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                                                            <Setter Property="Kind" Value="ClockAlertOutline"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </materialDesign:PackIcon.Style>
                                                        </materialDesign:PackIcon>
                                                        <TextBlock Text="Hủy tour" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>

                                                <Button Style="{StaticResource BookingRatingActionButton}" Margin="0,10,0,0" HorizontalAlignment="Stretch"
                                                        Visibility="{Binding ShowRatingAction, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        IsEnabled="{Binding CanRate, Mode=OneWay}"
                                                        ToolTip="{Binding RatingActionToolTip, Mode=OneWay}"
                                                        Command="{Binding DataContext.ShowRatingFormCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="StarOutline" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                                 Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                        <TextBlock Text="{Binding RatingActionText}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>

                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty bookings -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,48,0,56">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MyBookings.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Grid Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Ellipse Width="80" Height="80" Fill="#0A34C759"/>
                            <materialDesign:PackIcon Kind="TicketConfirmationOutline" Width="40" Height="40" Foreground="{StaticResource SuccessBrush}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Chưa có booking nào" HorizontalAlignment="Center"
                                   FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Khám phá và đặt tour yêu thích của bạn ngay!" HorizontalAlignment="Center"
                                   FontFamily="{StaticResource AppFont}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,20"/>
                        <Button Style="{StaticResource ApplePrimaryButton}" HorizontalAlignment="Center"
                                Command="{Binding NavigateToCommand}" CommandParameter="Book">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CompassOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Đặt tour ngay" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- ──── PAGE: PROFILE ──── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource AnimatedPageScrollViewer}"
                          Visibility="{Binding SelectedPage, Converter={StaticResource PageConverter}, ConverterParameter=Profile}">
                <StackPanel Margin="32,28,32,32">
                    <!-- Header -->
                    <StackPanel Margin="0,0,0,28">
                        <TextBlock Text="Thông tin cá nhân" Style="{StaticResource HeadingLargeStyle}"/>
                        <TextBlock Text="Quản lý thông tin tài khoản của bạn" Style="{StaticResource CaptionStyle}" FontSize="14" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Profile Card -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <!-- Edit Form -->
                        <Border Style="{StaticResource AppleCard}" Padding="28" Margin="0,0,20,0">
                            <StackPanel>
                                <TextBlock Text="Chỉnh sửa thông tin" FontFamily="{StaticResource AppFont}" FontSize="17" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,18">
                                        <TextBlock Text="Họ và tên *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBox Text="{Binding InfoFullName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleTextBox}"
                                                 materialDesign:HintAssist.Hint="Nhập họ tên"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,18">
                                        <TextBlock Text="Số điện thoại" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBox Text="{Binding InfoPhone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleTextBox}"
                                                 materialDesign:HintAssist.Hint="Nhập SĐT"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,18">
                                        <TextBlock Text="Email" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBox Text="{Binding InfoEmail, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleTextBox}"
                                                 materialDesign:HintAssist.Hint="Nhập email"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,18">
                                        <TextBlock Text="Địa chỉ" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBox Text="{Binding InfoAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleTextBox}"
                                                 materialDesign:HintAssist.Hint="Nhập địa chỉ"/>
                                    </StackPanel>
                                </Grid>

                                <Button Style="{StaticResource ApplePrimaryButton}" Command="{Binding SaveProfileCommand}"
                                        HorizontalAlignment="Left" Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Lưu thay đổi" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Profile Summary Card -->
                        <Border Grid.Column="1" Style="{StaticResource AppleCard}" Padding="28">
                            <StackPanel HorizontalAlignment="Center">
                                <!-- Avatar -->
                                <Grid Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,16">
                                    <Ellipse Width="80" Height="80">
                                        <Ellipse.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#007AFF" Offset="0"/>
                                                <GradientStop Color="#5AC8FA" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <Image Source="{Binding AvatarUrl}" Width="80" Height="80" Stretch="UniformToFill">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                        <Image.Clip>
                                            <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
                                        </Image.Clip>
                                    </Image>
                                    <TextBlock Text="{Binding UserInitials}" FontFamily="{StaticResource AppFont}" FontSize="28" FontWeight="Bold"
                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Text="{Binding FullName}" FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="Khách hàng V-Travel" FontFamily="{StaticResource AppFont}" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,20"/>
                                <Button Style="{StaticResource AppleGhostButton}" Command="{Binding ChangeAvatarCommand}" Margin="0,0,0,20">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CameraOutline" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ChangeAvatarButtonText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Quick Stats -->
                                <Border Height="1" Background="{StaticResource DividerBrush}" Margin="-12,0,-12,16"/>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Tổng booking" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding TotalBookingsCount}" FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Đang chờ" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding PendingBookingsCount}" FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Đã xác nhận" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding ConfirmedBookingsCount}" FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- ──── PAGE: NOTIFICATIONS ──── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource AnimatedPageScrollViewer}"
                          Visibility="{Binding SelectedPage, Converter={StaticResource PageConverter}, ConverterParameter=Notifications}">
                <StackPanel Margin="32,28,32,32">
                    <Grid Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Thông báo tài khoản" Style="{StaticResource HeadingLargeStyle}"/>
                            <TextBlock Style="{StaticResource CaptionStyle}" FontSize="14" Margin="0,6,0,0">
                                <Run Text="Bạn có "/>
                                <Run Text="{Binding UnreadNotificationCount, Mode=OneWay}"/>
                                <Run Text=" thông báo chưa đọc"/>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Style="{StaticResource AppleGhostButton}" Command="{Binding RefreshNotificationsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Làm mới" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ApplePrimaryButton}" Command="{Binding MarkAllNotificationsAsReadCommand}" Margin="10,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="EmailCheckOutline" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Đánh dấu tất cả đã đọc" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource AppleCard}" Padding="0">
                        <Grid>
                            <ItemsControl ItemsSource="{Binding AccountNotifications}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1" Padding="18,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid Width="42" Height="42" Margin="0,0,12,0">
                                                    <Ellipse Width="42" Height="42" Fill="#14007AFF"/>
                                                    <materialDesign:PackIcon Kind="BellOutline" Width="20" Height="20"
                                                                             Foreground="{StaticResource PrimaryBrush}"
                                                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>

                                                <StackPanel Grid.Column="1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Title}" FontFamily="{StaticResource AppFont}" FontSize="14"
                                                                   FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <Border Background="#11007AFF" CornerRadius="8" Padding="8,2" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding Category}" FontFamily="{StaticResource AppFont}" FontSize="11"
                                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Message}" FontFamily="{StaticResource AppFont}" FontSize="13"
                                                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                                               FontFamily="{StaticResource AppFont}" FontSize="11"
                                                               Foreground="{StaticResource TextTertiaryBrush}" Margin="0,8,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <Border Background="#1A34C759" CornerRadius="10" Padding="8,4" HorizontalAlignment="Right">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="Mới" FontFamily="{StaticResource AppFont}" FontSize="11"
                                                                   Foreground="{StaticResource SuccessBrush}"/>
                                                    </Border>

                                                    <Button Margin="0,8,0,0"
                                                            Command="{Binding DataContext.MarkNotificationAsReadCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource AppleGhostButton}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <TextBlock Text="Đánh dấu đã đọc"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel HorizontalAlignment="Center" Margin="0,60,0,60"
                                        Visibility="{Binding HasNoNotifications, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,14">
                                    <Ellipse Width="64" Height="64" Fill="#14007AFF"/>
                                    <materialDesign:PackIcon Kind="BellOffOutline" Width="30" Height="30"
                                                             Foreground="{StaticResource PrimaryBrush}"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="Chưa có thông báo nào" HorizontalAlignment="Center"
                                           FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Tất cả nhắc nhở, thanh toán và debug sẽ hiển thị tại đây."
                                           HorizontalAlignment="Center" Margin="0,6,0,0"
                                           FontFamily="{StaticResource AppFont}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ──── PAGE: DEBUG ──── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource AnimatedPageScrollViewer}"
                          Visibility="{Binding SelectedPage, Converter={StaticResource PageConverter}, ConverterParameter=Debug}">
                <StackPanel Margin="32,28,32,32">
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="Debug Tools" Style="{StaticResource HeadingLargeStyle}"/>
                        <TextBlock Text="Công cụ test nhanh thông báo dành cho QA/dev." Style="{StaticResource CaptionStyle}" FontSize="14" Margin="0,6,0,0"/>
                    </StackPanel>

                    <Border Style="{StaticResource AppleCard}" Padding="20">
                        <WrapPanel ItemWidth="250" ItemHeight="54">
                            <Button Style="{StaticResource ApplePrimaryButton}" Margin="0,0,12,12" Command="{Binding SimulatePaymentDebugCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CreditCardCheckOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="Giả lập xác nhận thanh toán"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ApplePrimaryButton}" Margin="0,0,12,12" Command="{Binding SimulateDepartureReminderDebugCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CalendarClockOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="Giả lập nhắc khởi hành"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource AppleGhostButton}" Margin="0,0,12,12" Command="{Binding SeedDebugNotificationsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="BellRingOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="Tạo batch 5 thông báo"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource AppleGhostButton}" Margin="0,0,12,12" Command="{Binding ForceDebugSyncCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="DatabaseSyncOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="Force sync dữ liệu thật"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource AppleGhostButton}" Margin="0,0,12,12" Command="{Binding MarkAllDebugNotificationsReadCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="EmailCheckOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="Đánh dấu tất cả đã đọc"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource AppleGhostButton}" Margin="0,0,12,12" Command="{Binding ClearDebugNotificationsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="BellOffOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="Xóa toàn bộ thông báo"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ──── BOOKING MODAL ──── -->
            <Border Background="#78000000"
                    Visibility="{Binding IsBookingModalOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBookingModalOverlayVisible}" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border Width="920" MaxHeight="720" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="28"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                            <TranslateTransform Y="10"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource AppleCard}">
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBookingModalOverlayVisible}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.30"
                                                                 EasingFunction="{StaticResource MotionEaseOut}"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                 To="1" Duration="0:0:0.33"
                                                                 EasingFunction="{StaticResource MotionSpringOut}"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                 To="1" Duration="0:0:0.33"
                                                                 EasingFunction="{StaticResource MotionSpringOut}"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" From="15" To="0" Duration="0:0:0.33"
                                                                 EasingFunction="{StaticResource MotionEaseOut}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="40" Height="40" Margin="0,0,14,0">
                                        <Ellipse Width="40" Height="40" Fill="#0A34C759"/>
                                        <materialDesign:PackIcon Kind="TicketConfirmationOutline" Width="20" Height="20" Foreground="{StaticResource SuccessBrush}"
                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Thông tin đặt tour" FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding SelectedDepartureInfo.TourName}" FontFamily="{StaticResource AppFont}" FontSize="13" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button Grid.Column="1" Style="{StaticResource AppleGhostButton}" Width="36" Height="36"
                                        Padding="8" VerticalAlignment="Top" Command="{Binding CancelBookingFormCommand}">
                                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                                </Button>
                            </Grid>

                            <Border Background="#FAFAFA" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="Điểm đến" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SelectedDepartureInfo.Destination}" FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="Ngày đi" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SelectedDepartureInfo.StartDateFormatted}" FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2" HorizontalAlignment="Right">
                                        <TextBlock Text="Ngày kết thúc" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SelectedDepartureInfo.EndDateFormatted}" FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,14,0,0">
                                        <TextBlock Text="Số chỗ còn lại" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold"/>
                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,0">
                                            <Run Text="{Binding SelectedDepartureInfo.AvailableSlots, Mode=OneWay}"/><Run Text=" chỗ"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" Margin="0,14,0,0">
                                        <TextBlock Text="Thời lượng" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold"/>
                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0">
                                            <Run Text="{Binding SelectedDepartureInfo.DurationDays, Mode=OneWay}"/><Run Text=" ngày"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right" Margin="0,14,0,0">
                                        <TextBlock Text="Giá/người" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SelectedDepartureInfo.PriceFormatted}" FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                                    <TextBlock Text="Họ tên *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding InfoFullName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleTextBox}" materialDesign:HintAssist.Hint="Nhập họ tên"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                                    <TextBlock Text="Số điện thoại *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding InfoPhone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleTextBox}" materialDesign:HintAssist.Hint="Nhập số điện thoại"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0">
                                    <TextBlock Text="Email *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding InfoEmail, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleTextBox}" materialDesign:HintAssist.Hint="Nhập email"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="2">
                                    <TextBlock Text="Địa chỉ *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding InfoAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleTextBox}" materialDesign:HintAssist.Hint="Nhập địa chỉ"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Số lượng khách *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding BookingGuestCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleTextBox}"
                                         materialDesign:HintAssist.Hint="Nhập số khách" Width="220" HorizontalAlignment="Left"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Mã giảm giá" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding PromoCodeInput, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource AppleTextBox}"
                                             materialDesign:HintAssist.Hint="VD: SUMMER2026"/>
                                    <Button Grid.Column="1" Margin="10,0,0,0"
                                            Style="{StaticResource AppleGhostButton}"
                                            Content="Kiểm tra mã"
                                            Command="{Binding CheckPromoCodeCommand}"/>
                                </Grid>

                                <TextBlock Text="{Binding PromoCodeStatusMessage}" Margin="0,8,0,0" FontFamily="{StaticResource AppFont}" FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPromoCodeStatusSuccess}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsPromoCodeStatusSuccess}" Value="False">
                                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PromoCodeStatusMessage}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PromoCodeStatusMessage}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource ApplePrimaryButton}" Command="{Binding ProceedToPaymentCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CreditCardOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Đặt ngay" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource AppleGhostButton}" Content="Hủy" Command="{Binding CancelBookingFormCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Border>

            <!-- ──── PAYMENT MODAL (MOCK QR) ──── -->
            <Border Background="#78000000"
                    Visibility="{Binding IsPaymentModalOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPaymentModalOverlayVisible}" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border Width="460" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                            <TranslateTransform Y="10"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource AppleCard}">
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPaymentModalOverlayVisible}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.30"
                                                                 EasingFunction="{StaticResource MotionEaseOut}"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                 To="1" Duration="0:0:0.33"
                                                                 EasingFunction="{StaticResource MotionSpringOut}"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                 To="1" Duration="0:0:0.33"
                                                                 EasingFunction="{StaticResource MotionSpringOut}"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" From="15" To="0" Duration="0:0:0.33"
                                                                 EasingFunction="{StaticResource MotionEaseOut}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Grid Width="38" Height="38" Margin="0,0,12,0">
                                <Ellipse Fill="#1A007AFF"/>
                                <materialDesign:PackIcon Kind="Qrcode" Width="20" Height="20" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <StackPanel>
                                <TextBlock Text="Thanh toán QR (Mock UI)" FontFamily="{StaticResource AppFont}" FontSize="17" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Không quét thật, chỉ mô phỏng giao diện thanh toán" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Background="#FAFAFA" CornerRadius="12" Padding="14" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{Binding PaymentTourName}" FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding PaymentScheduleText}" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding PaymentGuestText}" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding PaymentOriginalAmountFormatted, StringFormat=Tạm tính: {0}}" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding PaymentDiscountAmountFormatted, StringFormat=Giảm giá: {0}}" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource SuccessBrush}" Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding PaymentTotalFormatted, StringFormat=Thanh toán: {0}}" FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#E6E6E6" BorderThickness="1" CornerRadius="12" Padding="10" HorizontalAlignment="Center">
                            <Image Source="{Binding PaymentQrImageUrl}" Width="220" Height="220" Stretch="Fill"/>
                        </Border>

                        <TextBlock Text="Sau khi bấm 'Xác nhận thanh toán', hệ thống sẽ chuyển sang trạng thái đợi admin xác nhận." 
                                   FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" 
                                   TextWrapping="Wrap" Margin="0,14,0,0"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                            <Button Style="{StaticResource AppleGhostButton}" Content="Hủy" Command="{Binding CancelPaymentCommand}" Margin="0,0,10,0"/>
                            <Button Style="{StaticResource ApplePrimaryButton}" Command="{Binding ConfirmPaymentCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckCircleOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Xác nhận thanh toán" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>
            </Grid>

            <!-- ──── TOUR DETAILS MODAL ──── -->
            <Border x:Name="TourDetailsOverlay" Background="#5A10161D" Opacity="0"
                    IsVisibleChanged="TourDetailsOverlay_OnIsVisibleChanged"
                    Visibility="{Binding IsTourDetailsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTourDetailsVisible}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.30"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border x:Name="TourDetailsCard" Width="600" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="0" ClipToBounds="True"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="TourDetailsScaleTransform" ScaleX="0.975" ScaleY="0.975"/>
                            <TranslateTransform x:Name="TourDetailsTranslateTransform" Y="10"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource AppleCard}">
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTourDetailsVisible}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.36"
                                                                 EasingFunction="{StaticResource MotionEaseOut}"/>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                                                    <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.975"/>
                                                    <EasingDoubleKeyFrame KeyTime="0:0:0.24" Value="1.006" EasingFunction="{StaticResource MotionSpringOut}"/>
                                                    <EasingDoubleKeyFrame KeyTime="0:0:0.36" Value="1"/>
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                                                    <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.975"/>
                                                    <EasingDoubleKeyFrame KeyTime="0:0:0.24" Value="1.006" EasingFunction="{StaticResource MotionSpringOut}"/>
                                                    <EasingDoubleKeyFrame KeyTime="0:0:0.36" Value="1"/>
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" From="15" To="0" Duration="0:0:0.36"
                                                                 EasingFunction="{StaticResource MotionEaseOut}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Hero Image -->
                        <Border x:Name="TourDetailsHero" Grid.Row="0" Height="240" CornerRadius="16,16,0,0" Cursor="SizeAll"
                                MouseLeftButtonDown="TourDetailsHero_OnMouseLeftButtonDown"
                                MouseMove="TourDetailsHero_OnMouseMove"
                                MouseLeftButtonUp="TourDetailsHero_OnMouseLeftButtonUp"
                                LostMouseCapture="TourDetailsHero_OnLostMouseCapture">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding SelectedTour.ImageUrl, Mode=OneWay}" Stretch="UniformToFill"/>
                            </Border.Background>
                            <Grid>
                                <Border Background="#40000000" CornerRadius="16,16,0,0"/>
                                <Button Style="{StaticResource AppleGhostButton}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16" Padding="8" Width="36" Height="36" Background="#40000000" Foreground="White"
                                        Command="{Binding CloseTourDetailsCommand}">
                                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <StackPanel VerticalAlignment="Bottom" Margin="24">
                                    <Border Background="#60000000" CornerRadius="8" Padding="10,5" HorizontalAlignment="Left" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="MapMarkerOutline" Width="14" Height="14" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding SelectedTour.Destination, Mode=OneWay}" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="{Binding SelectedTour.Name, Mode=OneWay}" FontFamily="{StaticResource AppFont}" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Content Area -->
                        <StackPanel Grid.Row="1" Margin="24,24,24,24">
                            <!-- Quick Info -->
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Thời gian" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ClockOutline" Width="16" Height="16" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">
                                            <Run Text="{Binding SelectedTour.DurationDays, Mode=OneWay}"/><Run Text=" ngày"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Giá cơ bản" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}">
                                        <Run Text="{Binding SelectedTour.BasePrice, Mode=OneWay, StringFormat={}{0:N0}}"/><Run Text=" đ" FontSize="14" FontWeight="Normal"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding SelectedTour.RatingStarsText, Mode=OneWay}" FontFamily="{StaticResource AppFont}" FontSize="13"
                                               Foreground="{StaticResource WarningBrush}" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding SelectedTour.RatingSummaryText, Mode=OneWay}" FontFamily="{StaticResource AppFont}" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Line Separator -->
                            <Border Height="1" Background="{StaticResource DividerBrush}" Margin="0,0,0,24"/>

                            <!-- Description -->
                            <TextBlock Text="Chi tiết tour" FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedTour.Description, Mode=OneWay}" FontFamily="{StaticResource AppFont}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,16"/>
                                    <!-- Điểm tham quan -->
                                    <StackPanel Visibility="{Binding SelectedTour.HasAttractions, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,16">
                                        <TextBlock Text="Điểm tham quan nổi bật" FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding SelectedTour.Attractions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                        <materialDesign:PackIcon Kind="MapMarkerStarOutline" Width="16" Height="16" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}" FontFamily="{StaticResource AppFont}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <!-- Nơi ở / Khách sạn -->
                                    <StackPanel Visibility="{Binding SelectedTour.HasHotels, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,16">
                                        <TextBlock Text="Nơi lưu trú" FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding SelectedTour.Hotels}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                        <materialDesign:PackIcon Kind="BedOutline" Width="16" Height="16" Foreground="{StaticResource WarningBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}">
                                                            <Run Text="{Binding Name}"/>
                                                            <Run Text=" ("/><Run Text="{Binding StarRating}"/><Run Text=" Sao)"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <!-- Phương tiện -->
                                    <StackPanel Visibility="{Binding SelectedTour.HasTransports, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,16">
                                        <TextBlock Text="Phương tiện di chuyển" FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding SelectedTour.Transports}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                        <materialDesign:PackIcon Kind="CarMultiple" Width="16" Height="16" Foreground="{StaticResource SuccessBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}" FontFamily="{StaticResource AppFont}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Action Buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                                <Button Style="{StaticResource AppleGhostButton}" Content="Đóng" Command="{Binding CloseTourDetailsCommand}" Margin="0,0,12,0"/>
                                <Button Style="{StaticResource ApplePrimaryButton}" Command="{Binding GoToBookingFromSelectedTourCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CompassOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Đi thôi !" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>

            <!-- ──── APP DIALOG ──── -->
            <Border Background="#70000000"
                    Visibility="{Binding IsAppDialogVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAppDialogVisible}" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border Width="520" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                            <TranslateTransform Y="8"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource AppleCard}">
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAppDialogVisible}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.27"
                                                                 EasingFunction="{StaticResource MotionEaseOut}"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                 To="1" Duration="0:0:0.30"
                                                                 EasingFunction="{StaticResource MotionSpringOut}"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                 To="1" Duration="0:0:0.30"
                                                                 EasingFunction="{StaticResource MotionSpringOut}"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" From="15" To="0" Duration="0:0:0.30"
                                                                 EasingFunction="{StaticResource MotionEaseOut}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="{Binding AppDialogTitle}" FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding AppDialogMessage}" FontFamily="{StaticResource AppFont}" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" LineHeight="22"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button Style="{StaticResource AppleGhostButton}"
                                    Content="{Binding AppDialogSecondaryButtonText}"
                                    Command="{Binding CancelAppDialogCommand}"
                                    Visibility="{Binding IsAppDialogSecondaryVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Margin="0,0,10,0"/>
                            <Button Style="{StaticResource ApplePrimaryButton}"
                                    Command="{Binding ConfirmAppDialogCommand}">
                                <TextBlock Text="{Binding AppDialogPrimaryButtonText}"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Loading overlay -->
            <Border Background="#80FFFFFF" CornerRadius="0"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="48" Height="48" Style="{StaticResource MaterialDesignCircularProgressBar}"/>
                    <TextBlock Text="Đang tải dữ liệu..." FontFamily="{StaticResource AppFont}" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>




