<UserControl Style="{StaticResource AnimatedPageStyle}" x:Class="VietTravel.UI.Views.PromoCodeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,28,32,32">
            <Grid Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Quản lý mã giảm giá" Style="{StaticResource HeadingLargeStyle}"/>
                    <TextBlock Text="Tạo và kiểm soát coupon theo chiến dịch, tour và phân khúc khách hàng"
                               Style="{StaticResource CaptionStyle}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Command="{Binding ShowAddFormCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ApplePrimaryButton}">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSchemaWarning}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Tạo mã" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Style="{StaticResource AppleCard}" Padding="16" Margin="0,0,0,20"
                    Visibility="{Binding HasSchemaWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircleOutline" Width="20" Height="20" Foreground="{StaticResource WarningBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding SchemaWarningMessage}" FontFamily="{StaticResource AppFont}" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AppleCard}" Padding="24" Margin="0,0,0,20"
                    Visibility="{Binding IsFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding FormTitle}" FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Mã code *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding FormCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleSearchBox}"
                                     materialDesign:HintAssist.Hint="VD: SUMMER2026"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="Loại giảm *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding DiscountTypeOptions}" SelectedItem="{Binding FormDiscountType}" MinHeight="40"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Giá trị giảm *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding FormDiscountValue, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleSearchBox}"
                                     materialDesign:HintAssist.Hint="VD: 20 hoặc 200000"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="Đơn tối thiểu" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding FormMinOrderAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleSearchBox}"
                                     materialDesign:HintAssist.Hint="VD: 1000000"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Ngày bắt đầu" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding FormStartDate}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="Ngày kết thúc" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding FormEndDate}" />
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Tổng lượt dùng tối đa" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding FormMaxTotalUses, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleSearchBox}"
                                     materialDesign:HintAssist.Hint="Bỏ trống = không giới hạn"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="Lượt dùng mỗi người" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding FormMaxUsesPerUser, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleSearchBox}"
                                     materialDesign:HintAssist.Hint="Bỏ trống = không giới hạn"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Text="Chỉ áp dụng loại tour" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding FormApplicableTourType, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleSearchBox}"
                                     materialDesign:HintAssist.Hint="Bỏ trống = mọi loại tour"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#FAFAFA" CornerRadius="12" Padding="14" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Chỉ áp dụng cho các tour cụ thể" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold"/>
                            <ListBox ItemsSource="{Binding TourSelections}" Height="140" Margin="0,10,0,0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,2,0,2"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button Style="{StaticResource AppleGhostButton}" Content="Bỏ chọn tất cả tour"
                                    Command="{Binding ClearSelectedToursCommand}" HorizontalAlignment="Right" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <WrapPanel Margin="0,14,0,0">
                        <CheckBox Content="Chỉ dành cho khách hàng mới"
                                  IsChecked="{Binding FormOnlyNewCustomers}"
                                  Margin="0,0,24,0"/>
                        <CheckBox Content="Bật mã"
                                  IsChecked="{Binding FormIsActive}"/>
                    </WrapPanel>

                    <TextBlock Text="{Binding FormValidationMessage}" Foreground="{StaticResource ErrorBrush}" Margin="0,12,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FormValidationMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FormValidationMessage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Style="{StaticResource AppleGhostButton}" Content="Hủy" Command="{Binding CancelFormCommand}" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource ApplePrimaryButton}" Content="Lưu mã" Command="{Binding SavePromoCodeCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AppleCard}" Padding="16" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppleSearchBox}"
                                 materialDesign:HintAssist.Hint="Tìm kiếm theo mã, trạng thái hoặc phạm vi áp dụng"/>
                        <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Foreground="{StaticResource TextTertiaryBrush}"
                                                 VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                    </Grid>
                    <Button Grid.Column="1" Margin="12,0,0,0"
                            Command="{Binding RefreshCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource AppleGhostButton}">
                                <Setter Property="IsEnabled" Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSchemaWarning}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Làm mới" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Style="{StaticResource AppleCard}" Padding="0" Margin="0,0,0,20">
                <Grid>
                    <ProgressBar IsIndeterminate="True" Height="4" VerticalAlignment="Top"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <ListBox ItemsSource="{Binding FilteredPromoCodes}"
                             SelectedItem="{Binding SelectedPromoCode, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="16,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.1*"/>
                                            <ColumnDefinition Width="0.9*"/>
                                            <ColumnDefinition Width="0.8*"/>
                                            <ColumnDefinition Width="1.3*"/>
                                            <ColumnDefinition Width="0.8*"/>
                                            <ColumnDefinition Width="1.3*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Code}" FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding ScopeSummary}" FontFamily="{StaticResource AppFont}" FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" Text="{Binding DiscountSummary}" VerticalAlignment="Center"
                                                   FontFamily="{StaticResource AppFont}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="8,0,0,0"/>

                                        <Border Grid.Column="2" CornerRadius="10" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                Background="#0F000000" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusColor}" FontFamily="{StaticResource AppFont}"
                                                       FontWeight="SemiBold" FontSize="12"/>
                                        </Border>

                                        <TextBlock Grid.Column="3" Text="{Binding DateRange}" VerticalAlignment="Center"
                                                   FontFamily="{StaticResource AppFont}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,0"/>

                                        <TextBlock Grid.Column="4" Text="{Binding UsageSummary}" VerticalAlignment="Center"
                                                   FontFamily="{StaticResource AppFont}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="8,0,0,0"/>

                                        <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Style="{StaticResource AppleGhostButton}" Width="34" Height="34" Padding="0"
                                                    ToolTip="Chỉnh sửa"
                                                    Command="{Binding DataContext.ShowEditFormCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="PencilOutline" Width="16" Height="16" Foreground="{StaticResource PrimaryBrush}"/>
                                            </Button>
                                            <Button Style="{StaticResource AppleGhostButton}" Width="34" Height="34" Padding="0" Margin="4,0,0,0"
                                                    ToolTip="Bật / tắt mã"
                                                    Command="{Binding DataContext.ToggleActiveCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="CheckCircleOutline" Width="16" Height="16" Foreground="{StaticResource WarningBrush}"/>
                                            </Button>
                                            <Button Style="{StaticResource AppleGhostButton}" Width="34" Height="34" Padding="0" Margin="4,0,0,0"
                                                    ToolTip="Xóa mã"
                                                    Command="{Binding DataContext.DeletePromoCodeCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="DeleteOutline" Width="16" Height="16" Foreground="{StaticResource ErrorBrush}"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel HorizontalAlignment="Center" Margin="0,48,0,56"
                                Visibility="{Binding HasNoData, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Ellipse Width="64" Height="64" Fill="#0A007AFF"/>
                            <materialDesign:PackIcon Kind="TicketOutline" Width="32" Height="32" Foreground="{StaticResource PrimaryBrush}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Chưa có mã giảm giá" HorizontalAlignment="Center"
                                   FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Nhấn 'Tạo mã' để bắt đầu chiến dịch khuyến mãi" HorizontalAlignment="Center"
                                   FontFamily="{StaticResource AppFont}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource AppleCard}" Padding="20" Visibility="{Binding HasSelectedPromo, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Lịch sử sử dụng mã" FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding SelectedPromoCode.Code, StringFormat=Mã: {0}}" Style="{StaticResource CaptionStyle}" Margin="0,4,0,0"/>

                    <ItemsControl ItemsSource="{Binding SelectedPromoUsages}" Margin="0,14,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.8*"/>
                                            <ColumnDefinition Width="0.8*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding BookingId, StringFormat=BK-{0}}" Grid.Column="0" FontFamily="{StaticResource AppFont}" FontSize="12"/>
                                        <TextBlock Text="{Binding CustomerId, StringFormat=KH-{0}}" Grid.Column="1" FontFamily="{StaticResource AppFont}" FontSize="12"/>
                                        <TextBlock Text="{Binding OrderAmountText}" Grid.Column="2" FontFamily="{StaticResource AppFont}" FontSize="12"/>
                                        <TextBlock Text="{Binding DiscountAmountText}" Grid.Column="3" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource SuccessBrush}"/>
                                        <TextBlock Text="{Binding FinalAmountText}" Grid.Column="4" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding UsedAtText}" Grid.Column="5" FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

