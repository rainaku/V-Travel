<UserControl Style="{StaticResource AnimatedPageStyle}" x:Class="VietTravel.UI.Views.GuideRatingManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:views="clr-namespace:VietTravel.UI.Views"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,28,32,32">
            <Grid Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Đánh giá Hướng dẫn viên" Style="{StaticResource HeadingLargeStyle}"/>
                    <TextBlock Text="Kiểm duyệt phản hồi về hướng dẫn viên và phản hồi cho khách hàng" Style="{StaticResource CaptionStyle}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Style="{StaticResource AppleGhostButton}" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Làm mới" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <UniformGrid Columns="4" Margin="0,0,0,20">
                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="40" Height="40" Margin="0,0,12,0">
                            <Ellipse Width="40" Height="40" Fill="#1A007AFF"/>
                            <materialDesign:PackIcon Kind="StarOutline" Width="20" Height="20" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalRatings}" FontFamily="{StaticResource AppFont}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Tổng đánh giá" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="5,0,5,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="40" Height="40" Margin="0,0,12,0">
                            <Ellipse Width="40" Height="40" Fill="#1AFF9500"/>
                            <materialDesign:PackIcon Kind="ClockOutline" Width="20" Height="20" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding PendingRatings}" FontFamily="{StaticResource AppFont}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Chờ duyệt" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="5,0,5,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="40" Height="40" Margin="0,0,12,0">
                            <Ellipse Width="40" Height="40" Fill="#1A34C759"/>
                            <materialDesign:PackIcon Kind="CheckCircleOutline" Width="20" Height="20" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding ApprovedRatings}" FontFamily="{StaticResource AppFont}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Đã duyệt" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="40" Height="40" Margin="0,0,12,0">
                            <Ellipse Width="40" Height="40" Fill="#1AAF52DE"/>
                            <materialDesign:PackIcon Kind="StarFourPointsOutline" Width="20" Height="20" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding AverageRatingText}" FontFamily="{StaticResource AppFont}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Điểm trung bình" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource AppleCard}" Padding="16" Margin="0,0,0,20"
                    Visibility="{Binding HasSchemaWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircleOutline" Width="20" Height="20" Margin="0,0,10,0" Foreground="{StaticResource WarningBrush}" VerticalAlignment="Top"/>
                    <TextBlock Text="{Binding SchemaWarningMessage}" TextWrapping="Wrap"
                               FontFamily="{StaticResource AppFont}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AppleCard}" Padding="24" Margin="0,0,0,20"
                    Visibility="{Binding IsModerationPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Kiểm duyệt đánh giá HDV" FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">
                                <Run Text="{Binding SelectedRating.GuideName, Mode=OneWay}"/>
                                <Run Text=" • "/>
                                <Run Text="{Binding SelectedRating.CustomerName, Mode=OneWay}"/>
                                <Run Text=" • "/>
                                <Run Text="{Binding SelectedRating.TourName, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding SelectedRating.StarsText}" FontFamily="{StaticResource AppFont}" FontSize="15"
                                       Foreground="{StaticResource WarningBrush}" Margin="0,6,0,0"/>
                            <TextBlock Text="{Binding SelectedRating.Comment}" TextWrapping="Wrap"
                                       FontFamily="{StaticResource AppFont}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Trạng thái" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding ModerationStatuses}" SelectedItem="{Binding SelectedModerationStatus}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Chọn trạng thái"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Phản hồi Admin" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ModerationReply, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="110"
                             Style="{StaticResource AppleSearchBox}"
                             materialDesign:HintAssist.Hint="Nhập phản hồi hiển thị cho khách hàng"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Style="{StaticResource AppleGhostButton}" Content="Đóng" Command="{Binding CancelModerationCommand}" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource ApplePrimaryButton}" Content="Lưu phản hồi" Command="{Binding SaveModerationCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AppleCard}" Padding="16" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppleSearchBox}"
                                 materialDesign:HintAssist.Hint="Tìm theo khách hàng, HDV, tour, bình luận..."/>
                        <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Foreground="{StaticResource TextTertiaryBrush}"
                                                 VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                    </Grid>
                    <ComboBox Grid.Column="2" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Trạng thái"/>
                    <ComboBox Grid.Column="4" ItemsSource="{Binding StarOptions}" SelectedItem="{Binding SelectedStar}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Số sao"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource AppleCard}" Padding="0">
                <StackPanel>
                    <Grid Background="#FAFAFA">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="1.7*"/>
                            <ColumnDefinition Width="0.8*"/>
                            <ColumnDefinition Width="0.9*"/>
                            <ColumnDefinition Width="1.8*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="0.9*"/>
                        </Grid.ColumnDefinitions>
                        <Border CornerRadius="16,16,0,0" Background="#FAFAFA" Grid.ColumnSpan="7"/>
                        <TextBlock Text="Khách hàng" Grid.Column="0" Padding="20,14" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="HDV / Tour / Booking" Grid.Column="1" Padding="12,14" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Sao" Grid.Column="2" Padding="12,14" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Trạng thái" Grid.Column="3" Padding="12,14" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Bình luận" Grid.Column="4" Padding="12,14" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Phản hồi" Grid.Column="5" Padding="12,14" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Hành động" Grid.Column="6" Padding="12,14" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}" HorizontalAlignment="Center"/>
                    </Grid>

                    <Grid>
                        <ProgressBar IsIndeterminate="True" Height="4" Margin="0,16,0,0" VerticalAlignment="Top"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <ItemsControl ItemsSource="{Binding FilteredRatings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                                        <Grid Margin="0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.4*"/>
                                                <ColumnDefinition Width="1.7*"/>
                                                <ColumnDefinition Width="0.8*"/>
                                                <ColumnDefinition Width="0.9*"/>
                                                <ColumnDefinition Width="1.8*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="0.9*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="20,0,12,0" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding CustomerName}" FontFamily="{StaticResource AppFont}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding CustomerEmail}" FontFamily="{StaticResource AppFont}" FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding GuideName}" FontFamily="{StaticResource AppFont}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding TourName}" FontFamily="{StaticResource AppFont}" FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0">
                                                    <Run Text="Booking #"/>
                                                    <Run Text="{Binding BookingId, Mode=OneWay}"/>
                                                    <Run Text=" • Khởi hành "/>
                                                    <Run Text="{Binding DepartureDateText, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <TextBlock Text="{Binding StarsText}" Grid.Column="2" Padding="12,0" FontFamily="{StaticResource AppFont}" FontSize="13"
                                                       Foreground="{StaticResource WarningBrush}" VerticalAlignment="Top"/>

                                            <Border Grid.Column="3" CornerRadius="8" Padding="10,5" Margin="12,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding StatusColor}" Opacity="0.12"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding StatusLabel}" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold">
                                                    <TextBlock.Foreground>
                                                        <SolidColorBrush Color="{Binding StatusColor}"/>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </Border>

                                            <StackPanel Grid.Column="4" Margin="12,0" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding CommentPreview}" FontFamily="{StaticResource AppFont}" FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="5" Margin="12,0" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding AdminReplyPreview}" FontFamily="{StaticResource AppFont}" FontSize="13"
                                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding ModerationSummary}" FontFamily="{StaticResource AppFont}" FontSize="11"
                                                           Foreground="{StaticResource TextTertiaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="6" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top">
                                                <Button Style="{StaticResource AppleGhostButton}" Margin="0,0,0,6" ToolTip="Phản hồi / chỉnh sửa"
                                                        Command="{Binding DataContext.ShowModerationFormCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="MessageReplyTextOutline" Width="16" Height="16" Foreground="{StaticResource PrimaryBrush}"/>
                                                </Button>
                                                <Button Style="{StaticResource AppleGhostButton}" Margin="0,0,0,6" ToolTip="Duyệt"
                                                        Command="{Binding DataContext.ApproveRatingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="CheckCircleOutline" Width="16" Height="16" Foreground="{StaticResource SuccessBrush}"/>
                                                </Button>
                                                <Button Style="{StaticResource AppleGhostButton}" ToolTip="Ẩn đánh giá"
                                                        Command="{Binding DataContext.HideRatingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="EyeOffOutline" Width="16" Height="16" Foreground="{StaticResource ErrorBrush}"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel HorizontalAlignment="Center" Margin="0,48,0,56"
                                    Visibility="{Binding HasNoData, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Ellipse Width="64" Height="64" Fill="#1A007AFF"/>
                                <materialDesign:PackIcon Kind="AccountTieOutline" Width="30" Height="30" Foreground="{StaticResource PrimaryBrush}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Chưa có đánh giá hướng dẫn viên" HorizontalAlignment="Center"
                                       FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Đánh giá từ khách hàng sẽ xuất hiện tại đây để admin kiểm duyệt" HorizontalAlignment="Center"
                                       FontFamily="{StaticResource AppFont}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <views:AdminPaginationBar Margin="0,12,0,0"
                                      SummaryText="{Binding PaginationSummary}"
                                      CanGoPrevious="{Binding CanGoToPreviousPage}"
                                      CanGoNext="{Binding CanGoToNextPage}"
                                      ShowPagination="{Binding ShowPagination}"
                                      PreviousCommand="{Binding PreviousPageCommand}"
                                      NextCommand="{Binding NextPageCommand}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
