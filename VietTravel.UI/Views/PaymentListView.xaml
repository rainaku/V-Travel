<UserControl Style="{StaticResource AnimatedPageStyle}" x:Class="VietTravel.UI.Views.PaymentListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,28,32,32">

            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Quản lý Thanh Toán" Style="{StaticResource HeadingLargeStyle}"/>
                    <TextBlock Text="Theo dõi trạng thái thanh toán các booking" Style="{StaticResource CaptionStyle}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Stats -->
            <UniformGrid Columns="3" Margin="0,0,0,20">
                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="40" Height="40" Margin="0,0,12,0">
                            <Ellipse Width="40" Height="40" Fill="#1AFF3B30"/>
                            <materialDesign:PackIcon Kind="CreditCardOffOutline" Width="20" Height="20" Foreground="{StaticResource ErrorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding UnpaidCount}" FontFamily="{StaticResource AppFont}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Chưa TT / Đợi xác nhận" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="5,0,5,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="40" Height="40" Margin="0,0,12,0">
                            <Ellipse Width="40" Height="40" Fill="#1AFF9500"/>
                            <materialDesign:PackIcon Kind="CreditCardClockOutline" Width="20" Height="20" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding DepositCount}" FontFamily="{StaticResource AppFont}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Đã đặt cọc" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="40" Height="40" Margin="0,0,12,0">
                            <Ellipse Width="40" Height="40" Fill="#1A34C759"/>
                            <materialDesign:PackIcon Kind="CreditCardCheckOutline" Width="20" Height="20" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding PaidCount}" FontFamily="{StaticResource AppFont}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Đã thanh toán đủ" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Search -->
            <Border Style="{StaticResource AppleCard}" Padding="16" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource AppleSearchBox}"
                                 materialDesign:HintAssist.Hint="Tìm kiếm thanh toán..."/>
                        <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Foreground="{StaticResource TextTertiaryBrush}"
                                                 VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                    </Grid>
                    <Button Grid.Column="1" Style="{StaticResource AppleGhostButton}" Command="{Binding LoadDataCommand}" Margin="12,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Làm mới" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Data Table -->
            <Border Style="{StaticResource AppleCard}" Padding="0">
                <StackPanel>
                    <Grid Background="#FAFAFA">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.4*"/>
                            <ColumnDefinition Width="0.6*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="0.8*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="0.8*"/>
                        </Grid.ColumnDefinitions>
                        <Border CornerRadius="16,16,0,0" Background="#FAFAFA" Grid.ColumnSpan="7"/>
                        <TextBlock Text="ID" Grid.Column="0" Padding="20,14" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Booking" Grid.Column="1" Padding="12,14" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Tổng tiền" Grid.Column="2" Padding="12,14" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Đã thanh toán" Grid.Column="3" Padding="12,14" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Trạng thái" Grid.Column="4" Padding="12,14" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Phương thức" Grid.Column="5" Padding="12,14" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Hành động" Grid.Column="6" Padding="12,14" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}" HorizontalAlignment="Center"/>
                    </Grid>

                    <Grid>
                        <ProgressBar IsIndeterminate="True" Height="4" Margin="0,16,0,0" VerticalAlignment="Top"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <ItemsControl ItemsSource="{Binding FilteredPayments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                                        <Grid Margin="0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="0.4*"/>
                                                <ColumnDefinition Width="0.6*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="0.8*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="0.8*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Id}" Grid.Column="0" Padding="20,0,12,0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" FontFamily="{StaticResource AppFont}"/>
                                            <TextBlock Text="{Binding BookingId, StringFormat=BK-{0}}" Grid.Column="1" Padding="12,0" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} đ}" Grid.Column="2" Padding="12,0" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding PaidAmount, StringFormat={}{0:N0} đ}" Grid.Column="3" Padding="12,0" FontSize="13" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Status}" Grid.Column="4" Padding="12,0" FontSize="13" Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding PaymentMethod}" Grid.Column="5" Padding="12,0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Style="{StaticResource AppleGhostButton}" Width="32" Height="32" Padding="0" Cursor="Hand" ToolTip="Đánh dấu đã cọc"
                                                        Command="{Binding DataContext.MarkAsDepositCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="CurrencyUsd" Width="16" Height="16" Foreground="{StaticResource WarningBrush}"/>
                                                </Button>
                                                <Button Style="{StaticResource AppleGhostButton}" Width="32" Height="32" Padding="0" Margin="4,0,0,0" Cursor="Hand" ToolTip="Xác nhận thanh toán thành công"
                                                        Command="{Binding DataContext.MarkAsPaidCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="CheckCircleOutline" Width="16" Height="16" Foreground="{StaticResource SuccessBrush}"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty State -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,48,0,56"
                                    Visibility="{Binding HasNoData, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Ellipse Width="64" Height="64" Fill="#0A34C759"/>
                                <materialDesign:PackIcon Kind="CreditCardOutline" Width="32" Height="32" Foreground="{StaticResource SuccessBrush}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Chưa có thanh toán nào" HorizontalAlignment="Center"
                                       FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Thanh toán sẽ tự động tạo khi có booking" HorizontalAlignment="Center"
                                       FontFamily="{StaticResource AppFont}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>

