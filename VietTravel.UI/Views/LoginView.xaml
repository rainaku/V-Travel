<UserControl Style="{StaticResource AnimatedPageStyle}" x:Class="VietTravel.UI.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <Border CornerRadius="16" ClipToBounds="True">
        <Grid>
            <!-- Background Image -->
            <Border CornerRadius="0,0,16,16">
                <Border.Background>
                    <ImageBrush ImageSource="pack://application:,,,/UI/travel.png" Stretch="UniformToFill" />
                </Border.Background>
            </Border>

            <!-- Blue Overlay -->
            <Border CornerRadius="0,0,16,16" Background="#4D007AFF"/>

            <!-- Decorative Circles -->
            <Ellipse Width="400" Height="400" Opacity="0.08" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-100,-100,0,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#007AFF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="350" Height="350" Opacity="0.06" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-80,-80">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#5AC8FA" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Login Card -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="420"
                    Background="#F0FFFFFF" CornerRadius="24" Padding="48,40">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="4" Opacity="0.08" Direction="270"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Logo Icon -->
                    <Image Source="/UI/Assets/logo.png" Width="64" Height="64" Margin="0,0,0,8" HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>

                    <!-- Title -->
                    <TextBlock Text="Viet Travel" HorizontalAlignment="Center" Margin="0,0,0,4"
                               FontFamily="{StaticResource AppFont}" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Đăng nhập để tiếp tục" HorizontalAlignment="Center" Margin="0,0,0,32"
                               FontFamily="{StaticResource AppFont}" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <!-- Username Field -->
                    <TextBlock Text="Tên đăng nhập" Margin="4,0,0,6"
                               FontFamily="{StaticResource AppFont}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Grid Margin="0,0,0,16">
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppleTextBox}" Padding="40,12,14,12"/>
                        <materialDesign:PackIcon Kind="Account" Width="18" Height="18"
                                                 Foreground="{StaticResource TextTertiaryBrush}"
                                                 VerticalAlignment="Center" Margin="14,0,0,0"
                                                 IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Password Field -->
                    <TextBlock Text="Mật khẩu" Margin="4,0,0,6"
                               FontFamily="{StaticResource AppFont}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Grid Margin="0,0,0,8">
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource ApplePasswordBox}" 
                                     Padding="40,12,14,12" PasswordChanged="PasswordBox_PasswordChanged"/>
                        <materialDesign:PackIcon Kind="Lock" Width="18" Height="18"
                                                 Foreground="{StaticResource TextTertiaryBrush}"
                                                 VerticalAlignment="Center" Margin="14,0,0,0"
                                                 IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" 
                               HorizontalAlignment="Center" Margin="0,4,0,16" TextWrapping="Wrap"
                               FontFamily="{StaticResource AppFont}" FontSize="13"
                               Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- Login Button -->
                    <Button Command="{Binding LoginCommand}" Style="{StaticResource ApplePrimaryButton}"
                            Height="48" FontSize="15" Margin="0,8,0,0"
                            IsEnabled="{Binding IsNotLoading}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Đăng nhập" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <materialDesign:PackIcon Kind="ArrowRight" Width="18" Height="18" Margin="8,0,0,0"
                                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Register Link -->
                    <Button Command="{Binding ToRegisterPageCommand}" Style="{StaticResource AppleGhostButton}"
                            Height="32" Margin="0,12,0,0">
                        <TextBlock Text="Chưa có tài khoản? Đăng ký ngay" FontSize="13" Foreground="{StaticResource PrimaryBrush}"/>
                    </Button>

                    <!-- Loading -->
                    <ProgressBar IsIndeterminate="True" Height="3" Margin="0,16,0,0"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                 Foreground="{StaticResource PrimaryBrush}" Background="Transparent"
                                 BorderThickness="0"/>
                </StackPanel>
            </Border>

            <!-- Version -->
            <TextBlock Text="v1.0.0" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,20,12"
                       FontFamily="{StaticResource AppFont}" FontSize="11"
                       Foreground="{StaticResource TextTertiaryBrush}"/>
        </Grid>
    </Border>
</UserControl>


