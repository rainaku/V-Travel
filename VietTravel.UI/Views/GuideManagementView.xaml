<UserControl Style="{StaticResource AnimatedPageStyle}" x:Class="VietTravel.UI.Views.GuideManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:views="clr-namespace:VietTravel.UI.Views"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,28,32,32">

            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{Binding PageTitle}" Style="{StaticResource HeadingLargeStyle}"/>
                    <TextBlock Text="{Binding PageSubtitle}" Style="{StaticResource CaptionStyle}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource AppleGhostButton}" Command="{Binding LoadDataCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Làm mới" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Stats -->
            <UniformGrid Columns="3" Margin="0,0,0,20"
                         Visibility="{Binding ShowManagementSections, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="40" Height="40" Margin="0,0,12,0">
                            <Ellipse Width="40" Height="40" Fill="#1A007AFF"/>
                            <materialDesign:PackIcon Kind="AccountTie" Width="20" Height="20" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalGuides}" FontFamily="{StaticResource AppFont}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Tổng guide" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCard}" Margin="8,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="40" Height="40" Margin="0,0,12,0">
                            <Ellipse Width="40" Height="40" Fill="#1A34C759"/>
                            <materialDesign:PackIcon Kind="ClipboardCheckOutline" Width="20" Height="20" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalAssignments}" FontFamily="{StaticResource AppFont}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Phân công hiện có" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCard}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="40" Height="40" Margin="0,0,12,0">
                            <Ellipse Width="40" Height="40" Fill="#1AFF9500"/>
                            <materialDesign:PackIcon Kind="AlertOutline" Width="20" Height="20" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding UnassignedActiveTours}" FontFamily="{StaticResource AppFont}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Tour hoạt động chưa gán" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Assign Form -->
            <Border Style="{StaticResource AppleCard}" Padding="24" Margin="0,0,0,20"
                    Visibility="{Binding ShowManagementSections, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Gán guide cho tour" FontFamily="{StaticResource AppFont}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Hướng dẫn viên *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding AvailableGuides}"
                                      SelectedItem="{Binding FormSelectedGuide}"
                                      DisplayMemberPath="FullName"
                                      FontFamily="{StaticResource AppFont}" FontSize="13"
                                      materialDesign:HintAssist.Hint="Chọn hướng dẫn viên"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="Lịch khởi hành/Tour *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding AvailableDepartures}"
                                      SelectedItem="{Binding FormSelectedDeparture}"
                                      FontFamily="{StaticResource AppFont}" FontSize="13"
                                      materialDesign:HintAssist.Hint="Chọn lịch tour hoạt động">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Tour.Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text=" - " />
                                            <TextBlock Text="{Binding StartDate, StringFormat={}{0:dd/MM/yyyy}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Bắt đầu công việc *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding FormWorkStart}" FontFamily="{StaticResource AppFont}" FontSize="13"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="Kết thúc công việc *" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding FormWorkEnd}" FontFamily="{StaticResource AppFont}" FontSize="13"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Trạng thái" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding AssignmentStatusOptions}" SelectedItem="{Binding FormAssignmentStatus}" FontFamily="{StaticResource AppFont}" FontSize="13"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="Ghi chú" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding FormAssignmentNotes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleSearchBox}"
                                     materialDesign:HintAssist.Hint="VD: phụ trách đoàn miền Bắc"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Style="{StaticResource ApplePrimaryButton}" Command="{Binding AssignGuideCommand}"
                                IsEnabled="{Binding CanAdminEdit}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircleOutline" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Lưu phân công" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Guide Contact -->
            <Border Style="{StaticResource AppleCard}" Padding="16" Margin="0,0,0,20"
                    Visibility="{Binding ShowManagementSections, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Thông tin liên hệ hướng dẫn viên" FontFamily="{StaticResource AppFont}" FontSize="17" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Cập nhật số điện thoại, email, liên hệ khẩn cấp" Style="{StaticResource CaptionStyle}" Margin="0,2,0,0"/>
                        </StackPanel>

                        <Grid Grid.Column="1" MinWidth="280">
                            <TextBox Text="{Binding GuideSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppleSearchBox}"
                                     materialDesign:HintAssist.Hint="Tìm guide theo tên, SĐT, email..."/>
                            <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Foreground="{StaticResource TextTertiaryBrush}"
                                                     VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                        </Grid>
                    </Grid>

                    <Grid>
                        <ProgressBar IsIndeterminate="True" Height="4" Margin="0,6,0,0" VerticalAlignment="Top"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <StackPanel>
                            <Grid Background="#FAFAFA">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.4*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                </Grid.ColumnDefinitions>
                                <Border CornerRadius="12,12,0,0" Background="#FAFAFA" Grid.ColumnSpan="6"/>
                                <TextBlock Text="Hướng dẫn viên" Grid.Column="0" Padding="14,12" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                                <TextBlock Text="SĐT" Grid.Column="1" Padding="12,12" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                                <TextBlock Text="Email" Grid.Column="2" Padding="12,12" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                                <TextBlock Text="Liên hệ khẩn cấp" Grid.Column="3" Padding="12,12" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                                <TextBlock Text="Ghi chú" Grid.Column="4" Padding="12,12" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                                <TextBlock Text="Lưu" Grid.Column="5" Padding="12,12" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}" HorizontalAlignment="Center"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding FilteredGuides}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                                            <Grid Margin="0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.4*"/>
                                                    <ColumnDefinition Width="0.8*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="14,0,10,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FullName}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}"/>
                                                    <TextBlock Text="{Binding Username}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                                                </StackPanel>

                                                <TextBox Grid.Column="1" Margin="8,0" Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleSearchBox}" Padding="10,6"
                                                         IsEnabled="{Binding DataContext.CanAdminEdit, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                <TextBox Grid.Column="2" Margin="8,0" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleSearchBox}" Padding="10,6"
                                                         IsEnabled="{Binding DataContext.CanAdminEdit, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                <TextBox Grid.Column="3" Margin="8,0" Text="{Binding EmergencyContact, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleSearchBox}" Padding="10,6"
                                                         IsEnabled="{Binding DataContext.CanAdminEdit, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                <TextBox Grid.Column="4" Margin="8,0" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppleSearchBox}" Padding="10,6"
                                                         IsEnabled="{Binding DataContext.CanAdminEdit, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>

                                                <Button Grid.Column="5" Style="{StaticResource AppleGhostButton}" Width="84" HorizontalAlignment="Center"
                                                        IsEnabled="{Binding DataContext.CanAdminEdit, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Command="{Binding DataContext.SaveGuideContactCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="15" Height="15" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Lưu" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,48"
                                    Visibility="{Binding HasNoGuides, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,12">
                                <Ellipse Width="64" Height="64" Fill="#0A007AFF"/>
                                <materialDesign:PackIcon Kind="AccountSearchOutline" Width="30" Height="30" Foreground="{StaticResource PrimaryBrush}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Chưa có hướng dẫn viên" HorizontalAlignment="Center"
                                       FontFamily="{StaticResource AppFont}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Admin hãy tạo user role Guide ở mục Người dùng &amp; Role." HorizontalAlignment="Center"
                                       FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <views:AdminPaginationBar Margin="0,0,0,20"
                                      SummaryText="{Binding GuidePaginationSummary}"
                                      CanGoPrevious="{Binding CanGoToPreviousGuidePage}"
                                      CanGoNext="{Binding CanGoToNextGuidePage}"
                                      ShowPagination="{Binding ShowGuidePagination}"
                                      PreviousCommand="{Binding PreviousGuidePageCommand}"
                                      NextCommand="{Binding NextGuidePageCommand}"/>

            <!-- Schedule -->
            <Border Style="{StaticResource AppleCard}" Padding="16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Lịch làm việc hướng dẫn viên" FontFamily="{StaticResource AppFont}" FontSize="17" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Theo dõi các tour đã được phân công" Style="{StaticResource CaptionStyle}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Grid Grid.Column="1" MinWidth="280">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Margin="0,0,12,0">
                                <TextBox Text="{Binding ScheduleSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource AppleSearchBox}"
                                         materialDesign:HintAssist.Hint="Tìm theo guide, tour..."/>
                                <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Foreground="{StaticResource TextTertiaryBrush}"
                                                         VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                            </Grid>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding ScheduleStatuses}" SelectedItem="{Binding SelectedScheduleStatus}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Trạng thái"
                                      Padding="12,10"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="#E5E5EA"
                                      materialDesign:TextFieldAssist.HasClearButton="False"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>

                    <Grid>
                        <ProgressBar IsIndeterminate="True" Height="4" Margin="0,6,0,0" VerticalAlignment="Top"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <StackPanel>
                            <Grid Background="#FAFAFA">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1.4*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="0.9*"/>
                                    <ColumnDefinition Width="1.4*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                </Grid.ColumnDefinitions>
                                <Border CornerRadius="12,12,0,0" Background="#FAFAFA" Grid.ColumnSpan="7"/>
                                <TextBlock Text="Guide" Grid.Column="0" Padding="14,12" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                                <TextBlock Text="Tour" Grid.Column="1" Padding="12,12" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                                <TextBlock Text="Khởi hành" Grid.Column="2" Padding="12,12" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                                <TextBlock Text="Làm việc" Grid.Column="3" Padding="12,12" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                                <TextBlock Text="Trạng thái" Grid.Column="4" Padding="12,12" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                                <TextBlock Text="Ghi chú" Grid.Column="5" Padding="12,12" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                                <TextBlock Text="Thao tác" Grid.Column="6" Padding="12,12" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}" HorizontalAlignment="Center"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding FilteredAssignments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                                            <Grid Margin="0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.1*"/>
                                                    <ColumnDefinition Width="1.4*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="0.9*"/>
                                                    <ColumnDefinition Width="1.4*"/>
                                                    <ColumnDefinition Width="1.1*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding GuideName}" Grid.Column="0" Padding="14,0,10,0" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding TourName}" Grid.Column="1" Padding="12,0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding DepartureStartDate, StringFormat={}{0:dd/MM/yyyy}}" Grid.Column="2" Padding="12,0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="8,0">
                                                    <DatePicker SelectedDate="{Binding WorkStart}" FontSize="12" Width="118"
                                                                IsEnabled="{Binding DataContext.CanAdminEdit, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                    <TextBlock Text=" - " VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0"/>
                                                    <DatePicker SelectedDate="{Binding WorkEnd}" FontSize="12" Width="118"
                                                                IsEnabled="{Binding DataContext.CanAdminEdit, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                </StackPanel>

                                                <ComboBox Grid.Column="4" Margin="8,0"
                                                          ItemsSource="{Binding DataContext.AssignmentStatusOptions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          SelectedItem="{Binding Status, UpdateSourceTrigger=PropertyChanged}"
                                                          FontSize="12" FontFamily="{StaticResource AppFont}"
                                                          IsEnabled="{Binding DataContext.CanAdminEdit, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>

                                                <TextBox Grid.Column="5" Margin="8,0"
                                                         Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource AppleSearchBox}" Padding="10,6"
                                                         IsEnabled="{Binding DataContext.CanAdminEdit, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>

                                                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Style="{StaticResource AppleGhostButton}" Width="36" Height="32" Margin="0,0,4,0"
                                                            IsEnabled="{Binding DataContext.CanAdminEdit, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            Command="{Binding DataContext.SaveAssignmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}">
                                                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16" Foreground="{StaticResource PrimaryBrush}"/>
                                                    </Button>
                                                    <Button Style="{StaticResource AppleGhostButton}" Width="36" Height="32"
                                                            IsEnabled="{Binding DataContext.CanAdminEdit, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            Command="{Binding DataContext.DeleteAssignmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}">
                                                        <materialDesign:PackIcon Kind="DeleteOutline" Width="16" Height="16" Foreground="{StaticResource ErrorBrush}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,48"
                                    Visibility="{Binding HasNoAssignments, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,12">
                                <Ellipse Width="64" Height="64" Fill="#0A34C759"/>
                                <materialDesign:PackIcon Kind="CalendarBlankOutline" Width="30" Height="30" Foreground="{StaticResource SuccessBrush}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Chưa có lịch làm việc nào" HorizontalAlignment="Center"
                                       FontFamily="{StaticResource AppFont}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <views:AdminPaginationBar Margin="0,12,0,0"
                                      SummaryText="{Binding AssignmentPaginationSummary}"
                                      CanGoPrevious="{Binding CanGoToPreviousAssignmentPage}"
                                      CanGoNext="{Binding CanGoToNextAssignmentPage}"
                                      ShowPagination="{Binding ShowAssignmentPagination}"
                                      PreviousCommand="{Binding PreviousAssignmentPageCommand}"
                                      NextCommand="{Binding NextAssignmentPageCommand}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
