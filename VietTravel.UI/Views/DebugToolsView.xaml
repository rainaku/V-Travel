<UserControl Style="{StaticResource AnimatedPageStyle}" x:Class="VietTravel.UI.Views.DebugToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,28,32,32">
            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="Debug Tools" Style="{StaticResource HeadingLargeStyle}"/>
                <TextBlock Text="Công cụ test nhanh luồng thông báo (chỉ dùng nội bộ)." Style="{StaticResource CaptionStyle}" Margin="0,4,0,0"/>
            </StackPanel>

            <UniformGrid Columns="2" Margin="0,0,0,20">
                <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="40" Height="40" Margin="0,0,12,0">
                            <Ellipse Width="40" Height="40" Fill="#1A007AFF"/>
                            <materialDesign:PackIcon Kind="BellOutline" Width="20" Height="20" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding NotificationCount}" FontFamily="{StaticResource AppFont}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Tổng thông báo hiện có" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="40" Height="40" Margin="0,0,12,0">
                            <Ellipse Width="40" Height="40" Fill="#1AFF3B30"/>
                            <materialDesign:PackIcon Kind="BellBadgeOutline" Width="20" Height="20" Foreground="{StaticResource ErrorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding UnreadCount}" FontFamily="{StaticResource AppFont}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Thông báo chưa đọc" FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource AppleCard}" Padding="18">
                <WrapPanel ItemWidth="260" ItemHeight="54">
                    <Button Style="{StaticResource ApplePrimaryButton}" Margin="0,0,12,12" Command="{Binding SimulatePaymentConfirmationCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CreditCardCheckOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Giả lập xác nhận thanh toán"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ApplePrimaryButton}" Margin="0,0,12,12" Command="{Binding SimulateDepartureReminderCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CalendarClockOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Giả lập nhắc khởi hành"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource AppleGhostButton}" Margin="0,0,12,12" Command="{Binding SeedNotificationBatchCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BellRingOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Tạo batch 5 thông báo"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource AppleGhostButton}" Margin="0,0,12,12" Command="{Binding ForceSyncCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseSyncOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Force sync dữ liệu thật"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource AppleGhostButton}" Margin="0,0,12,12" Command="{Binding MarkAllAsReadCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="EmailCheckOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Đánh dấu tất cả đã đọc"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource AppleGhostButton}" Margin="0,0,12,12" Command="{Binding ClearNotificationsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BellOffOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Xóa toàn bộ thông báo"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

