<UserControl Style="{StaticResource AnimatedPageStyle}" x:Class="VietTravel.UI.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <Border CornerRadius="16" ClipToBounds="True">
        <Grid>
            <!-- Background Image -->
            <Border CornerRadius="0,0,16,16">
                <Border.Background>
                    <ImageBrush ImageSource="pack://application:,,,/UI/travel.png" Stretch="UniformToFill" />
                </Border.Background>
            </Border>

            <!-- Blue Overlay -->
            <Border CornerRadius="0,0,16,16" Background="#4D007AFF"/>

            <!-- Decorative Circles -->
            <Ellipse Width="400" Height="400" Opacity="0.08" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-100,-100,0,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#007AFF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="350" Height="350" Opacity="0.06" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-80,-80">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#5AC8FA" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Register Card -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="420"
                    Background="#F0FFFFFF" CornerRadius="24" Padding="48,32">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="4" Opacity="0.08" Direction="270"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Logo Icon -->
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Ellipse Width="64" Height="64" Opacity="0.12">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#007AFF" Offset="0"/>
                                    <GradientStop Color="#AF52DE" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <materialDesign:PackIcon Kind="AccountPlusOutline" Width="30" Height="30" 
                                                 Foreground="{StaticResource PrimaryBrush}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Title -->
                    <TextBlock Text="Đăng Ký Tài Khoản" HorizontalAlignment="Center" Margin="0,0,0,4"
                               FontFamily="{StaticResource AppFont}" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Tham gia Viet Travel ngay hôm nay" HorizontalAlignment="Center" Margin="0,0,0,24"
                               FontFamily="{StaticResource AppFont}" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <!-- Full Name Field -->
                    <TextBlock Text="Họ và tên" Margin="4,0,0,6"
                               FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Grid Margin="0,0,0,14">
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppleTextBox}" Padding="40,10,14,10"/>
                        <materialDesign:PackIcon Kind="AccountDetailsOutline" Width="18" Height="18"
                                                 Foreground="{StaticResource TextTertiaryBrush}"
                                                 VerticalAlignment="Center" Margin="14,0,0,0"
                                                 IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Username Field -->
                    <TextBlock Text="Tên đăng nhập" Margin="4,0,0,6"
                               FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Grid Margin="0,0,0,14">
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppleTextBox}" Padding="40,10,14,10"/>
                        <materialDesign:PackIcon Kind="AccountOutline" Width="18" Height="18"
                                                 Foreground="{StaticResource TextTertiaryBrush}"
                                                 VerticalAlignment="Center" Margin="14,0,0,0"
                                                 IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Phone Field -->
                    <TextBlock Text="Số điện thoại" Margin="4,0,0,6"
                               FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Grid Margin="0,0,0,14">
                        <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppleTextBox}" Padding="40,10,14,10"/>
                        <materialDesign:PackIcon Kind="PhoneOutline" Width="18" Height="18"
                                                 Foreground="{StaticResource TextTertiaryBrush}"
                                                 VerticalAlignment="Center" Margin="14,0,0,0"
                                                 IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Email Field -->
                    <TextBlock Text="Gmail" Margin="4,0,0,6"
                               FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Grid Margin="0,0,0,14">
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppleTextBox}" Padding="40,10,14,10"/>
                        <materialDesign:PackIcon Kind="EmailOutline" Width="18" Height="18"
                                                 Foreground="{StaticResource TextTertiaryBrush}"
                                                 VerticalAlignment="Center" Margin="14,0,0,0"
                                                 IsHitTestVisible="False"/>
                    </Grid>


                    <!-- Address Field -->
                    <TextBlock Text="Địa chỉ" Margin="4,0,0,6"
                               FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Grid Margin="0,0,0,14">
                        <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppleTextBox}" Padding="40,10,14,10"/>
                        <materialDesign:PackIcon Kind="MapMarkerOutline" Width="18" Height="18"
                                                 Foreground="{StaticResource TextTertiaryBrush}"
                                                 VerticalAlignment="Center" Margin="14,0,0,0"
                                                 IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Password Field -->
                    <TextBlock Text="Mật khẩu" Margin="4,0,0,6"
                               FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Grid Margin="0,0,0,14">
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource ApplePasswordBox}" 
                                     Padding="40,10,14,10" PasswordChanged="PasswordBox_PasswordChanged"/>
                        <materialDesign:PackIcon Kind="LockOutline" Width="18" Height="18"
                                                 Foreground="{StaticResource TextTertiaryBrush}"
                                                 VerticalAlignment="Center" Margin="14,0,0,0"
                                                 IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Confirm Password Field -->
                    <TextBlock Text="Xác nhận mật khẩu" Margin="4,0,0,6"
                               FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Grid Margin="0,0,0,8">
                        <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource ApplePasswordBox}" 
                                     Padding="40,10,14,10" PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                        <materialDesign:PackIcon Kind="LockOutline" Width="18" Height="18"
                                                 Foreground="{StaticResource TextTertiaryBrush}"
                                                 VerticalAlignment="Center" Margin="14,0,0,0"
                                                 IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" 
                               HorizontalAlignment="Center" Margin="0,4,0,12" TextWrapping="Wrap"
                               FontFamily="{StaticResource AppFont}" FontSize="12"
                               Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- Register Button -->
                    <Button Command="{Binding RegisterCommand}" Style="{StaticResource ApplePrimaryButton}"
                            Height="44" FontSize="14" Margin="0,4,0,0"
                            IsEnabled="{Binding IsNotLoading}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Đăng ký ngay" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <!-- Back to Login -->
                    <Button Command="{Binding BackToLoginCommand}" Style="{StaticResource AppleGhostButton}"
                            Height="32" Margin="0,12,0,0">
                        <TextBlock Text="Đã có tài khoản? Đăng nhập" FontSize="13" Foreground="{StaticResource PrimaryBrush}"/>
                    </Button>

                    <!-- Loading Indicator -->
                    <ProgressBar IsIndeterminate="True" Height="3" Margin="0,8,0,0"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                 Foreground="{StaticResource PrimaryBrush}" Background="Transparent"
                                 BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>

