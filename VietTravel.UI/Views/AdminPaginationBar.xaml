<UserControl x:Class="VietTravel.UI.Views.AdminPaginationBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="44">
    <Border Background="Transparent"
            Visibility="{Binding ShowPagination, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding SummaryText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource AppFont}"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource AppleGhostButton}"
                        Command="{Binding PreviousCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        IsEnabled="{Binding CanGoPrevious, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <TextBlock Text="Trang trước"/>
                </Button>

                <Button Style="{StaticResource AppleGhostButton}"
                        Margin="8,0,0,0"
                        Command="{Binding NextCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        IsEnabled="{Binding CanGoNext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <TextBlock Text="Trang sau"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
